{%- liquid
  assign rating = rating | default: 5 | times: 1.0
  assign size = size | default: 'sm'
-%}
<span class="stars {{ size }}" aria-label="Rated {{ rating }} out of 5">
  {%- for i in (1..5) -%}
    {%- if forloop.index0 < rating -%}
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l3.1 6.3 7 1-5.05 4.9 1.2 6.9L12 17.8l-6.25 3.3 1.2-6.9L1.9 9.3l7-1L12 2z"/></svg>
    {%- else -%}
      <svg viewBox="0 0 24 24" class="star-empty" aria-hidden="true"><path d="M12 2l3.1 6.3 7 1-5.05 4.9 1.2 6.9L12 17.8l-6.25 3.3 1.2-6.9L1.9 9.3l7-1L12 2z"/></svg>
    {%- endif -%}
  {%- endfor -%}
</span>
