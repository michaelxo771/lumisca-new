<div class="toast" data-toast="recent" role="status" aria-live="polite" aria-hidden="true">
  <div class="toast-img ph aspect-square"><span class="ph-label" data-toast-product>Product</span></div>
  <div style="min-width:0; flex:1;">
    <p style="font-size: 14px; line-height: 1.25;">
      <strong data-toast-name>Sarah</strong> from <strong data-toast-loc>Manchester</strong>
    </p>
    <p class="muted" style="font-size: 12px; line-height: 1.25; margin-top: 2px;">
      Just bought the <strong style="color: var(--ink);" data-toast-product>Pro Hair Growth Cap</strong>
    </p>
    <p style="font-size: 10px; letter-spacing: .1em; text-transform: uppercase; color: var(--red); margin-top: 4px;">✓ <span data-toast-mins>5 mins ago</span></p>
  </div>
</div>

{%- stylesheet -%}
.toast-img { width: 56px; height: 56px; flex-shrink: 0; }
.toast-img .ph-label { font-size: 9px; }
{%- endstylesheet -%}
