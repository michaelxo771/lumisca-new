<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=5">
    <meta name="theme-color" content="#0A0A0A">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {%- render 'meta-tags' -%}

    {{ 'theme.css' | asset_url | stylesheet_tag }}

    <script>
      window.LUMISCA = {
        routes: {
          cart_url: '{{ routes.cart_url }}',
          cart_add_url: '{{ routes.cart_add_url }}',
          cart_change_url: '{{ routes.cart_change_url }}',
          cart_update_url: '{{ routes.cart_update_url }}',
          search_url: '{{ routes.search_url }}'
        },
        money_format: {{ shop.money_format | json }},
        free_shipping_threshold: {{ settings.free_shipping_threshold | default: 50 | times: 100 }},
        bundle_handle: {{ settings.bundle_product_handle | default: 'lumisca-complete-bundle' | json }},
        autoApplySave90: {%- if settings.auto_apply_save90 == false -%}false{%- else -%}true{%- endif -%},
        strings: {
          added_to_cart: {{ 'cart.added' | t | json }},
          free_shipping_unlocked: {{ 'cart.free_shipping_unlocked' | t | json }},
          free_shipping_away: {{ 'cart.free_shipping_away' | t | json }}
        }
      };
    </script>

    {{ content_for_header }}

    {% comment %} Meta Pixel — manual install with Advanced Matching. Browser-side PageView only; ViewContent / AddToCart / InitiateCheckout / Purchase are handled server-side via Shopify's Meta sales channel auto-Web-Pixel (CAPI). {% endcomment %}
    <script>
    (function () {
      function getCookie(n) { var m = document.cookie.match(new RegExp('(?:^|; )' + n + '=([^;]*)')); return m ? decodeURIComponent(m[1]) : ''; }
      function setCookie(n, v, days) { var d = new Date(); d.setTime(d.getTime() + days*864e5); document.cookie = n + '=' + encodeURIComponent(v) + '; expires=' + d.toUTCString() + '; path=/; SameSite=Lax'; }

      // external_id — minted once per browser, persists 2 years.
      var eid = getCookie('lumisca_eid');
      if (!eid) {
        eid = (window.crypto && crypto.randomUUID) ? crypto.randomUUID() : (Date.now().toString(36) + Math.random().toString(36).slice(2));
        setCookie('lumisca_eid', eid, 730);
      }

      // Build Advanced Matching object. Server-rendered hashes for logged-in customer fields use Liquid's sha256 filter.
      var am = { country: {{ localization.country.iso_code | downcase | json }}, external_id: eid };
      var emCookie = getCookie('lumisca_em_h');
      var emCustomer = {{ customer.email | downcase | strip | sha256 | json | default: '""' }};
      if (emCookie) am.em = emCookie; else if (emCustomer) am.em = emCustomer;
      var fnHash = {{ customer.first_name | downcase | strip | sha256 | json | default: '""' }};
      var lnHash = {{ customer.last_name | downcase | strip | sha256 | json | default: '""' }};
      var ctHash = {{ customer.default_address.city | downcase | replace: ' ', '' | sha256 | json | default: '""' }};
      var zpHash = {{ customer.default_address.zip | downcase | strip | sha256 | json | default: '""' }};
      var phHash = {{ customer.phone | replace: ' ', '' | replace: '-', '' | replace: '(', '' | replace: ')', '' | sha256 | json | default: '""' }};
      if (fnHash) am.fn = fnHash;
      if (lnHash) am.ln = lnHash;
      if (ctHash) am.ct = ctHash;
      if (zpHash) am.zp = zpHash;
      if (phHash) am.ph = phHash;

      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '1291530356261006', am);
      fbq('track', 'PageView');
    })();
    </script>
    <noscript><img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=1291530356261006&ev=PageView&noscript=1"
    /></noscript>
    {% comment %} End Meta Pixel {% endcomment %}
  </head>
  <body class="template-{{ template.name | handle }}">
    <a class="skip-link" href="#main">Skip to content</a>

    {%- comment -%}
      PHASE 2: SAVE90 launch-edition sticky bar above the header. Dismissable;
      stays hidden via localStorage for 24h once dismissed. Cap-friendly copy
      that references the £90-off code; benign on every page.
    {%- endcomment -%}
    <div class="cap-launch-strip" data-cap-launch-strip hidden>
      <div class="container cap-launch-strip-inner">
        <span class="cap-launch-strip-msg">🎁 UK Spring Launch: <strong>£90 off</strong> the Pro Red Light Cap — code <strong>SAVE90</strong></span>
        <button type="button" class="cap-launch-strip-close" data-cap-launch-strip-close aria-label="Dismiss launch banner">×</button>
      </div>
    </div>

    {% section 'header' %}

    <main id="main" role="main">
      {{ content_for_layout }}
    </main>

    {%- comment -%}
      Footer rendered globally from the layout. Templates must NOT
      include a 'footer' section or it will render twice.
    {%- endcomment -%}
    {% section 'footer' %}

    {%- render 'cart-drawer' -%}
    {%- render 'mobile-nav' -%}
    {%- render 'popup-welcome' -%}
    {%- render 'popup-exit' -%}
    {%- render 'popup-cart-upsell' -%}
    {%- render 'popup-cookie' -%}
    {%- render 'toast-recent-purchase' -%}
    {%- render 'back-to-top' -%}

    <script src="{{ 'theme.js' | asset_url }}" defer></script>
  </body>
</html>
