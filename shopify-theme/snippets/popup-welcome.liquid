<div class="popup popup-welcome" data-popup="welcome" data-popup-key="lumisca.welcome" role="dialog" aria-label="Welcome offer" aria-hidden="true">
  <div class="popup-backdrop"></div>
  <div class="popup-dialog popup-split">
    <button type="button" class="popup-close" data-popup-close aria-label="Close">{% render 'icon-close' %}</button>
    <div class="popup-media ph ph-dark aspect-square"><span class="ph-label">Lumisca Welcome</span></div>
    <div class="popup-body">
      <p class="eyebrow" style="color: var(--gold);">Welcome to Lumisca</p>
      <div data-popup-main>
        <h2 class="display-md" style="margin-bottom: 1rem; line-height: 1.2;">Get <span style="color: var(--red);">10% off</span> your first order.</h2>
        <p class="muted" style="line-height: 1.65; margin-bottom: 1.5rem;">Join 10,000+ UK customers. We'll email your discount code, plus early access to new devices.</p>
        <form data-popup-form style="display:flex; flex-direction:column; gap:.75rem;">
          <label>
            <span class="sr-only">Email address</span>
            <input type="email" required placeholder="Your email address" class="popup-input">
          </label>
          <button type="submit" class="btn btn-red btn-block">Send My 10% Off Code</button>
        </form>
        <p style="font-size: 11px; color: rgba(249,247,244,.5); margin-top: 1rem; line-height: 1.6;">
          Code: <span style="color: var(--gold); font-weight: 600;">{{ settings.welcome_discount_code }}</span> · Unsubscribe anytime.
        </p>
      </div>
      <div data-popup-success class="hidden">
        <h2 class="display-md" style="margin-bottom: 1rem; line-height: 1.2;">Check your inbox.</h2>
        <p class="muted" style="line-height: 1.65;">Your <strong style="color: var(--gold);">10% off code</strong> is on its way. Welcome to the Lumisca family.</p>
      </div>
    </div>
  </div>
</div>

{%- stylesheet -%}
.popup-split { display: grid; grid-template-columns: 1fr; max-width: 720px; width: 100%; }
@media (min-width: 768px) { .popup-split { grid-template-columns: 1fr 1fr; } }
.popup-media { aspect-ratio: 1/1; display: none; }
@media (min-width: 768px) { .popup-media { display: flex; aspect-ratio: auto; min-height: 420px; } }
.popup-body { padding: 1.75rem; }
@media (min-width: 768px) { .popup-body { padding: 2.25rem; } }
.popup-close { position: absolute; top: .75rem; right: .75rem; width: 40px; height: 40px; display: inline-flex; align-items: center; justify-content: center; color: rgba(255,255,255,.7); z-index: 10; }
.popup-close:hover { color: #fff; }
.popup-input { width: 100%; height: 48px; padding: 0 1rem; background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.15); color: #fff; outline: none; }
.popup-input::placeholder { color: rgba(255,255,255,.5); }
.popup-input:focus { border-color: var(--red); }
{%- endstylesheet -%}
