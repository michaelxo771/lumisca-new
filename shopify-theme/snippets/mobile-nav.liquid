<div class="mobile-nav" data-mobile-nav aria-hidden="true">
  <div class="mobile-nav-header container">
    <span class="header-logo">{{ shop.name | upcase }}</span>
    <button class="icon-btn" type="button" data-mobile-nav-close aria-label="Close menu">{% render 'icon-close' %}</button>
  </div>
  <nav class="mobile-nav-body container" aria-label="Mobile">
    <ul>
      {%- for link in linklists.main-menu.links -%}
        <li>
          <a href="{{ link.url }}" data-mobile-nav-close>
            {{ link.title }}
            {% render 'icon-arrow-right' %}
          </a>
        </li>
      {%- endfor -%}
    </ul>
    <div class="mobile-nav-cta">
      <p class="mobile-nav-cta-title">{{ settings.tagline }}</p>
      <p class="mobile-nav-cta-sub">Free UK delivery · 60-day money back</p>
      <a href="/collections/all" class="btn btn-red btn-block" data-mobile-nav-close>Shop The Collection</a>
    </div>
  </nav>
</div>

{%- stylesheet -%}
.mobile-nav-header { height: 64px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--line); }
.mobile-nav-body { flex: 1; overflow-y: auto; padding: 2rem 1rem; }
.mobile-nav-body ul { display: flex; flex-direction: column; }
.mobile-nav-body li a { display: flex; align-items: center; justify-content: space-between; padding: 1.25rem 0; border-bottom: 1px solid var(--line); font-family: var(--display); font-size: 1.75rem; line-height: 1; }
.mobile-nav-cta { margin-top: 2.5rem; padding: 1.5rem; background: var(--ink); color: var(--cream); }
.mobile-nav-cta-title { font-family: var(--display); font-size: 1.25rem; margin-bottom: .5rem; }
.mobile-nav-cta-sub { font-size: 13px; color: rgba(249,247,244,.7); margin-bottom: 1.25rem; }
{%- endstylesheet -%}
