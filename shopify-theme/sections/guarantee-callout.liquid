<section class="section-lg section-dark guarantee" style="position:relative; overflow:hidden;">
  <div class="hero-glow" style="opacity:.6;"></div>
  <div class="container center" style="position:relative; max-width: 48rem;">
    <div class="guarantee-icon">
      <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M12 3l8 4v5c0 5-3.5 8-8 9-4.5-1-8-4-8-9V7l8-4z"/>
        <path d="M9 12l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <h2 class="display-lg" style="margin-bottom:1rem;">{{ section.settings.heading }}</h2>
    <p class="muted" style="font-size:1.125rem; line-height:1.7; margin-bottom: 2rem;">{{ section.settings.body }}</p>
    {%- if section.settings.cta_label != blank -%}
      <a href="{{ section.settings.cta_url }}" class="btn btn-red btn-lg">{{ section.settings.cta_label }}</a>
    {%- endif -%}
  </div>
</section>

{%- stylesheet -%}
.guarantee-icon { display: inline-flex; align-items: center; justify-content: center; width: 80px; height: 80px; border-radius: 50%; background: var(--red); color: #fff; margin-bottom: 1.5rem; }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Guarantee Callout",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "60-Day Money-Back Guarantee" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Try any Lumisca device for 60 days. If you don't see results — or simply don't love it — we'll refund you in full, no questions asked." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop The Collection" },
    { "type": "url", "id": "cta_url", "label": "CTA link" }
  ],
  "presets": [ { "name": "Guarantee Callout" } ]
}
{% endschema %}
