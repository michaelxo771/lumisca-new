<section class="section-dark not-found" style="position:relative; overflow:hidden;">
  <div class="hero-glow" style="opacity:.7;"></div>
  <div class="container center" style="position:relative; padding: 5rem 1rem; max-width: 40rem;">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="display-xl" style="margin-bottom:1rem;">{{ section.settings.heading }}</h1>
    <p class="muted" style="font-size:1.125rem; line-height:1.7; margin-bottom: 2rem;">{{ section.settings.body }}</p>
    <div style="display:flex; flex-direction:column; gap:.75rem; justify-content:center;">
      <a href="/" class="btn btn-red btn-lg">Go Home</a>
      <a href="/collections/all" class="btn btn-outline-light btn-lg">Shop The Collection</a>
    </div>
  </div>
</section>

{%- stylesheet -%}
@media (min-width: 640px) { .not-found > div > div:last-child { flex-direction: row !important; } }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Not Found",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "404" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "This page is off-grid." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "The link you followed doesn't exist, or the page has moved. Let's get you back to the light." }
  ],
  "presets": [ { "name": "404" } ]
}
{% endschema %}
