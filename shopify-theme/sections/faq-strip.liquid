<section class="section-lg faq-strip" style="border-top: 1px solid var(--line);">
  <div class="container" style="max-width: 56rem;">
    <div class="center" style="margin-bottom: 2.5rem;">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="display-lg">{{ section.settings.heading }}</h2>
    </div>
    <div class="accordion">
      {%- for block in section.blocks -%}
        <div class="accordion-item" {{ block.shopify_attributes }}>
          <button class="accordion-trigger" type="button" aria-expanded="false">
            {{ block.settings.question }}
            <span class="accordion-icon">{% render 'icon-plus' %}</span>
          </button>
          <div class="accordion-panel">{{ block.settings.answer }}</div>
        </div>
      {%- endfor -%}
    </div>
    {%- if section.settings.cta_label != blank -%}
      <div class="center" style="margin-top: 2.5rem;">
        <a href="{{ section.settings.cta_url }}" class="faq-more">{{ section.settings.cta_label }} {% render 'icon-arrow-right' %}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{%- stylesheet -%}
.faq-more { display: inline-flex; align-items: center; gap: .5rem; font-size: 13px; letter-spacing: .15em; text-transform: uppercase; font-weight: 500; }
.faq-more:hover { color: var(--red); }
{%- endstylesheet -%}

{% schema %}
{
  "name": "FAQ Strip",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "FAQ" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Questions, answered." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "View Full FAQ" },
    { "type": "url", "id": "cta_url", "label": "CTA link" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "max_blocks": 12,
  "default": {
    "blocks": [
      { "type": "faq", "settings": { "question": "Is red light therapy safe?", "answer": "<p>Yes. Non-invasive, drug-free, clinically studied for over 20 years in dermatology. There are no known side effects when used as directed. Every Lumisca device carries CE certification and is calibrated to clinical wavelengths.</p>" } },
      { "type": "faq", "settings": { "question": "How long before I see results?", "answer": "<p>Hair results typically week 8-12, skin from week 4, sleep from night one. Consistency is the single biggest factor — 4-5 sessions per week, every week.</p>" } },
      { "type": "faq", "settings": { "question": "Can I use multiple devices?", "answer": "<p>Yes, many customers use the full routine daily. Glow Mask morning, Pro Cap afternoon, Rest Mask before bed. The Complete Bundle is designed for this and saves you over £174.</p>" } },
      { "type": "faq", "settings": { "question": "What is your returns policy?", "answer": "<p>60-day money back guarantee, no questions asked. Contact support@lumisca.com within 60 days of delivery for a full refund.</p>" } },
      { "type": "faq", "settings": { "question": "How long does UK delivery take?", "answer": "<p>Free UK delivery via tracked courier, 3-5 working days. Order before 3pm Monday-Friday for same-day dispatch.</p>" } },
      { "type": "faq", "settings": { "question": "Is this suitable for sensitive skin?", "answer": "<p>Yes — light therapy only, no chemicals or heat, suitable for all skin types. If you have photosensitivity or are on photosensitising medication, check with your GP first.</p>" } }
    ]
  },
  "presets": [ { "name": "FAQ Strip" } ]
}
{% endschema %}
