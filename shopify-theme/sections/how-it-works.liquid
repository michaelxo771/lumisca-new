<section class="section-lg how" style="background: rgba(232,230,227,.4);">
  <div class="container">
    <div class="center how-head">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="display-lg">{{ section.settings.heading }}</h2>
    </div>
    <div class="grid grid-md-3">
      {%- for block in section.blocks -%}
        <div class="how-card" {{ block.shopify_attributes }}>
          <div class="how-num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</div>
          <h3 class="how-title">{{ block.settings.title }}</h3>
          <p class="muted">{{ block.settings.body }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- stylesheet -%}
.how-head { max-width: 36rem; margin: 0 auto 3rem; }
.how-card { position: relative; background: var(--cream); padding: 2rem; border: 1px solid var(--line); }
@media (min-width: 768px) { .how-card { padding: 2.5rem; } }
.how-num { width: 56px; height: 56px; border-radius: 50%; background: var(--red); color: #fff; display: inline-flex; align-items: center; justify-content: center; font-family: var(--display); font-size: 20px; margin-bottom: 1.25rem; }
.how-title { font-family: var(--display); font-size: 1.5rem; margin-bottom: .75rem; }
{%- endstylesheet -%}

{% schema %}
{
  "name": "How It Works",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "How It Works" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Results In 3 Simple Steps" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Choose Your Device" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "Hair, skin, sleep — or the Complete Bundle and save £174. Ships free across the UK." }
      ]
    }
  ],
  "max_blocks": 3,
  "default": {
    "blocks": [
      { "type": "step", "settings": { "title": "Choose Your Device", "body": "Hair, skin, sleep — or the Complete Bundle and save £174. Ships free across the UK." } },
      { "type": "step", "settings": { "title": "Use Daily 20-25 Mins", "body": "Hands-free sessions you fit around life — while you work, watch or wind down." } },
      { "type": "step", "settings": { "title": "See Visible Results", "body": "Sleep from night one. Skin from week 4. Hair regrowth from week 8-12. Backed by our 60-day guarantee." } }
    ]
  },
  "presets": [ { "name": "How It Works" } ]
}
{% endschema %}
