<section class="section-dark science-hero" style="position:relative; overflow:hidden;">
  <div class="hero-glow" style="opacity:.7;"></div>
  <div class="container center" style="position:relative; max-width: 56rem; padding: 5rem 1rem;">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="display-xl" style="margin-bottom:1.5rem;">{{ section.settings.heading }}</h1>
    <p class="muted" style="font-size: 1.125rem; line-height: 1.7;">{{ section.settings.body }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Science Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Science" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Red Light Therapy Actually Does." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "The clinical research, the biology, the wavelengths that matter — and what it means for your hair, skin and sleep." }
  ],
  "presets": [ { "name": "Science Hero" } ]
}
{% endschema %}
