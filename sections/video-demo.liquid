<section class="video-demo" data-fade-up>
  <div class="container">
    <div class="video-demo-head">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="display-lg">{{ section.settings.heading }}</h2>
    </div>

    <div class="video-demo-grid">
      {%- for block in section.blocks -%}
        <article class="video-demo-card" {{ block.shopify_attributes }}>
          <div class="video-demo-video-wrap">
            <video
              class="video-demo-video"
              muted
              loop
              playsinline
              preload="metadata"
              data-autoplay-mobile
              {% if block.settings.poster != blank %}poster="{{ block.settings.poster | asset_url }}"{% endif %}
            >
              <source src="{{ block.settings.video_filename | asset_url }}" type="video/mp4">
            </video>
          </div>
          <div class="video-demo-body">
            <h3 class="video-demo-title">{{ block.settings.title }}</h3>
            <p class="video-demo-sub muted">{{ block.settings.body }}</p>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- stylesheet -%}
.video-demo { background: var(--cream); padding: 100px 0; }
@media (max-width: 768px) { .video-demo { padding: 60px 0; } }
.video-demo-head { text-align: center; margin-bottom: 3rem; max-width: 40rem; margin-left: auto; margin-right: auto; }
.video-demo-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
@media (min-width: 900px) { .video-demo-grid { grid-template-columns: 1fr 1fr; gap: 2rem; } }
.video-demo-card { background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 10px 40px -12px rgba(10,10,10,.12); transition: transform .3s ease, box-shadow .3s ease; }
.video-demo-card:hover { transform: translateY(-4px); box-shadow: 0 20px 60px -20px rgba(10,10,10,.2); }
.video-demo-video-wrap { position: relative; aspect-ratio: 16/10; background: #111; overflow: hidden; }
.video-demo-video { width: 100%; height: 100%; object-fit: cover; display: block; }
.video-demo-body { padding: 1.5rem 1.75rem 2rem; }
.video-demo-title { font-family: var(--display); font-size: 1.5rem; line-height: 1.25; margin-bottom: .5rem; }
.video-demo-sub { font-size: 15px; line-height: 1.65; }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Video Demo Strip",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "SEE IT IN ACTION" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Premium engineering, made simple." }
  ],
  "blocks": [
    {
      "type": "demo",
      "name": "Demo",
      "settings": [
        { "type": "text", "id": "video_filename", "label": "Video asset filename", "default": "demo-hair-cap.mp4" },
        { "type": "text", "id": "poster", "label": "Poster image filename" },
        { "type": "text", "id": "title", "label": "Title", "default": "The Hair Growth Cap" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "660nm + 850nm wavelengths, clinically proven for hair density." }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Video Demo Strip",
      "blocks": [
        { "type": "demo", "settings": { "video_filename": "demo-hair-cap.mp4", "poster": "product-cap-solo.png", "title": "The Hair Growth Cap", "body": "660nm + 850nm wavelengths, clinically proven for hair density." } },
        { "type": "demo", "settings": { "video_filename": "demo-face-mask.mp4", "poster": "product-mask-solo.png", "title": "The Face Mask", "body": "4 wavelengths to tackle fine lines, acne and dullness in 10 minutes." } }
      ]
    }
  ]
}
{% endschema %}
