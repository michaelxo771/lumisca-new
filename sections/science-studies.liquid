<section class="section-lg science-studies" style="background: rgba(232,230,227,.4);">
  <div class="container" style="max-width: 56rem;">
    <div style="margin-bottom: 2.5rem;">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="display-lg">{{ section.settings.heading }}</h2>
    </div>
    <ul style="display:flex; flex-direction:column; gap: 1.25rem;">
      {%- for block in section.blocks -%}
        <li class="study" {{ block.shopify_attributes }}>
          <p class="eyebrow" style="color: var(--mid); margin-bottom: .5rem;">{{ block.settings.journal }}</p>
          <h3 class="study-title">{{ block.settings.title }}</h3>
          <p class="muted" style="line-height:1.7;">{{ block.settings.takeaway }}</p>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</section>

{%- stylesheet -%}
.study { background: var(--cream); border: 1px solid var(--line); padding: 1.5rem; }
@media (min-width: 768px) { .study { padding: 2rem; } }
.study-title { font-family: var(--display); font-size: clamp(1.125rem, 2vw, 1.5rem); line-height: 1.3; margin-bottom: .75rem; }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Science Studies",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "References" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Peer-reviewed studies we stand on." }
  ],
  "blocks": [
    { "type": "study", "name": "Study", "settings": [
      { "type": "text", "id": "journal", "label": "Journal" },
      { "type": "text", "id": "title", "label": "Study title" },
      { "type": "textarea", "id": "takeaway", "label": "Takeaway" }
    ] }
  ],
  "max_blocks": 6,
  "default": {
    "blocks": [
      { "type": "study", "settings": { "journal": "Journal of Cosmetic and Laser Therapy", "title": "Avram & Rogers (2009) — Low-Level Laser Therapy for Hair Regrowth", "takeaway": "12-month randomised controlled trial of 110 patients with androgenetic alopecia. Active LLLT group saw a 39% increase in terminal hair count vs. 0.75% in the sham group." } },
      { "type": "study", "settings": { "journal": "Seminars in Cutaneous Medicine and Surgery", "title": "Barolet (2009) — Light-Emitting Diodes in Dermatology", "takeaway": "Comprehensive review of clinical applications. Red light in the 630-660nm range demonstrated significant effects on collagen synthesis, wound healing and reduction of inflammation." } },
      { "type": "study", "settings": { "journal": "BBA Clinical", "title": "Hamblin (2016) — Shining Light on the Head: Photobiomodulation for Brain Disorders", "takeaway": "Review of transcranial photobiomodulation. 810-850nm near-infrared light penetrates deeply, increases mitochondrial ATP production, and has measurable effects on neurological and cellular function." } }
    ]
  },
  "presets": [ { "name": "Science Studies" } ]
}
{% endschema %}
