<section class="section-dark reviews-hero" style="position:relative; overflow:hidden;">
  <div class="hero-glow" style="opacity:.7;"></div>
  <div class="container center" style="position:relative; max-width: 56rem; padding: 5rem 1rem;">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="display-xl" style="margin-bottom:1.25rem;">{{ section.settings.heading }}</h1>
    <p class="muted" style="font-size:1.125rem; line-height:1.7; max-width: 36rem; margin: 0 auto;">{{ section.settings.body }}</p>
    <div class="rh-avg">
      <div class="rh-avg-n">{{ section.settings.avg }}</div>
      <div>
        {% render 'star-rating', rating: 5, size: 'md' %}
        <p class="eyebrow" style="color: rgba(249,247,244,.7); margin-top: .25rem;">{{ section.settings.caption }}</p>
      </div>
    </div>
  </div>
</section>

{%- stylesheet -%}
.rh-avg { margin-top: 2rem; display: inline-flex; align-items: center; gap: 1rem; padding: 1rem 1.5rem; border: 1px solid rgba(255,255,255,.15); background: rgba(255,255,255,.05); }
.rh-avg-n { font-family: var(--display); font-size: 3rem; line-height: 1; }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Reviews Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Reviews" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "10,000+ customers. 4.9 stars." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Every review below is from a verified UK buyer. Real names, real results, real timelines." },
    { "type": "text", "id": "avg", "label": "Average rating", "default": "4.9" },
    { "type": "text", "id": "caption", "label": "Caption", "default": "From 2,847 verified UK reviews" }
  ],
  "presets": [ { "name": "Reviews Hero" } ]
}
{% endschema %}
