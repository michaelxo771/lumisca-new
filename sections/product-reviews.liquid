{%- liquid
  assign rating = product.metafields.reviews.rating | default: 4.9
  assign review_count = product.metafields.reviews.count | default: 0
-%}
<section class="section product-reviews-sec" style="background: rgba(232,230,227,.3); border-top: 1px solid var(--line);">
  <div class="container">
    <div class="pr-head">
      <div>
        <p class="eyebrow">Reviews</p>
        <h2 class="display-md">What Customers Are Saying</h2>
      </div>
      <div style="display:flex; align-items:center; gap:.75rem;">
        {% render 'star-rating', rating: rating, size: 'md' %}
        <p style="font-size:14px;"><strong>{{ rating }}/5</strong> <span class="muted">from {{ review_count | default: 1248 }} reviews</span></p>
      </div>
    </div>
    <div class="grid grid-md-2">
      {%- for block in section.blocks -%}
        <article class="pr-card" {{ block.shopify_attributes }}>
          <div class="pr-top">
            {% render 'star-rating', rating: 5, size: 'sm' %}
            <span class="pr-verified">✓ Verified Buyer</span>
          </div>
          <h3 class="pr-title">{{ block.settings.title }}</h3>
          <p class="pr-body">“{{ block.settings.body }}”</p>
          <div class="pr-meta muted">
            <strong style="color:var(--ink);">{{ block.settings.name }}</strong> · {{ block.settings.location }} · {{ block.settings.date }}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- stylesheet -%}
.pr-head { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2.5rem; }
@media (min-width: 768px) { .pr-head { flex-direction: row; align-items: flex-end; justify-content: space-between; } }
.pr-card { background: #fff; border: 1px solid var(--line); padding: 1.5rem; }
@media (min-width: 768px) { .pr-card { padding: 2rem; } }
.pr-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: .75rem; }
.pr-verified { font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: var(--red); font-weight: 600; }
.pr-title { font-family: var(--display); font-size: 18px; margin-bottom: .5rem; line-height: 1.3; }
.pr-body { color: rgba(10,10,10,.9); line-height: 1.7; }
.pr-meta { margin-top: 1.25rem; padding-top: 1rem; border-top: 1px solid var(--line); font-size: 14px; }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Product Reviews",
  "settings": [],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Genuinely impressed." },
        { "type": "textarea", "id": "body", "label": "Body", "default": "I've been losing my hair since menopause and tried everything. 10 weeks with the Lumisca cap and I genuinely can't believe the difference." },
        { "type": "text", "id": "name", "label": "Name", "default": "Sarah M." },
        { "type": "text", "id": "location", "label": "Location", "default": "Manchester" },
        { "type": "text", "id": "date", "label": "Date", "default": "12 March 2026" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [ { "name": "Product Reviews" } ]
}
{% endschema %}
