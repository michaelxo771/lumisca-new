<section class="section-lg about-values" style="background: rgba(232,230,227,.4);">
  <div class="container">
    <div class="center" style="max-width: 36rem; margin: 0 auto 3rem;">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="display-lg">{{ section.settings.heading }}</h2>
    </div>
    <div class="grid grid-md-3">
      {%- for block in section.blocks -%}
        <div class="av-card" {{ block.shopify_attributes }}>
          <div class="av-icon">{{ block.settings.icon }}</div>
          <h3 class="av-title">{{ block.settings.title }}</h3>
          <p class="muted">{{ block.settings.body }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- stylesheet -%}
.av-card { background: var(--cream); padding: 2rem; border: 1px solid var(--line); }
@media (min-width: 768px) { .av-card { padding: 2.5rem; } }
.av-icon { font-size: 2.25rem; margin-bottom: 1rem; }
.av-title { font-family: var(--display); font-size: 1.5rem; margin-bottom: .75rem; }
{%- endstylesheet -%}

{% schema %}
{
  "name": "About Values",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "What We Stand For"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Three values. Every decision."
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Emoji",
          "default": "🔬"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Science-Backed"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body",
          "default": "Every wavelength, intensity and session length is calibrated to peer-reviewed research."
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "About Values"
    }
  ]
}
{% endschema %}
