<section class="section section-dark product-science-sec">
  <div class="hero-glow" style="opacity:.8;"></div>
  <div class="container" style="position:relative;">
    <div class="ps-grid">
      <div>
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="display-md" style="margin-bottom:1.25rem;">{{ section.settings.heading }}</h2>
        <p class="muted" style="line-height:1.65; margin-bottom:1.5rem;">{{ section.settings.body }}</p>
        <a href="{{ section.settings.cta_url }}" class="btn btn-outline-light">{{ section.settings.cta_label }}</a>
      </div>
      <div class="ps-stats">
        {%- for block in section.blocks -%}
          <div {{ block.shopify_attributes }}>
            <div class="ps-stat-n">{{ block.settings.value }}</div>
            <p class="muted">{{ block.settings.label }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{%- stylesheet -%}
.ps-grid { display: grid; gap: 2.5rem; align-items: center; }
@media (min-width: 768px) { .ps-grid { grid-template-columns: 2fr 3fr; gap: 3rem; } }
.ps-stats { display: grid; gap: 1rem; }
@media (min-width: 640px) { .ps-stats { grid-template-columns: repeat(3, 1fr); } }
.ps-stats > div { background: rgba(255,255,255,.05); border: 1px solid rgba(201,168,76,.3); padding: 1.5rem; }
.ps-stat-n { font-family: var(--display); font-size: 2.25rem; color: var(--gold); margin-bottom: .75rem; line-height: 1; }
.ps-stats p { font-size: 14px; line-height: 1.6; }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Product Science",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Science"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Clinically studied. Engineered for you."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Calibrated to the same clinical parameters shown in peer-reviewed studies to drive measurable outcomes."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Read The Research"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "650nm"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Peak absorption for hair follicles"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Product Science"
    }
  ]
}
{% endschema %}
