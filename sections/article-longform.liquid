{%- liquid
  assign current_handle = page.handle | default: section.settings.handle
  assign meta_label = section.settings.meta_label | default: '8 min read · Lumisca Science Team'
-%}

<article class="lf">
  <header class="lf-hero">
    <div class="lf-hero-inner">
      {%- if section.settings.category != blank -%}
        <span class="lf-eyebrow">{{ section.settings.category }}</span>
      {%- endif -%}
      <h1 class="lf-title">{{ section.settings.heading }}</h1>
      {%- if section.settings.subtitle != blank -%}
        <p class="lf-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
      <p class="lf-meta">{{ meta_label }}</p>
    </div>
  </header>

  <div class="lf-body">
    <div class="lf-body-inner">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'paragraph' -%}
            <div class="lf-p" {{ block.shopify_attributes }}>{{ block.settings.body }}</div>
          {%- when 'subheading' -%}
            <h2 class="lf-h2" {{ block.shopify_attributes }}>{{ block.settings.text }}</h2>
          {%- when 'pull_quote' -%}
            <blockquote class="lf-quote" {{ block.shopify_attributes }}>
              <p>{{ block.settings.quote }}</p>
              {%- if block.settings.attribution != blank -%}
                <cite>— {{ block.settings.attribution }}</cite>
              {%- endif -%}
            </blockquote>
          {%- when 'stat_block' -%}
            <div class="lf-stats" {{ block.shopify_attributes }}>
              {%- if block.settings.stat1_value != blank -%}
                <div class="lf-stat">
                  <div class="lf-stat-n">{{ block.settings.stat1_value }}</div>
                  <p class="lf-stat-l">{{ block.settings.stat1_label }}</p>
                </div>
              {%- endif -%}
              {%- if block.settings.stat2_value != blank -%}
                <div class="lf-stat">
                  <div class="lf-stat-n">{{ block.settings.stat2_value }}</div>
                  <p class="lf-stat-l">{{ block.settings.stat2_label }}</p>
                </div>
              {%- endif -%}
              {%- if block.settings.stat3_value != blank -%}
                <div class="lf-stat">
                  <div class="lf-stat-n">{{ block.settings.stat3_value }}</div>
                  <p class="lf-stat-l">{{ block.settings.stat3_label }}</p>
                </div>
              {%- endif -%}
            </div>
          {%- when 'callout' -%}
            <aside class="lf-callout" {{ block.shopify_attributes }}>
              {%- if block.settings.title != blank -%}<p class="lf-callout-title">{{ block.settings.title }}</p>{%- endif -%}
              <div class="lf-callout-body">{{ block.settings.body }}</div>
            </aside>
          {%- when 'citation' -%}
            <p class="lf-citation" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
        {%- endcase -%}
      {%- endfor -%}

      <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="lf-cta-card">
        <span class="lf-cta-text">{{ section.settings.cta_label }}</span>
        <span class="lf-cta-arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>

  {%- comment -%} Related articles — hard-coded directory, filter self {%- endcomment -%}
  {%- assign art_handles = 'science-wavelengths,science-hair-loss,science-skin,science-studies' | split: ',' -%}
  {%- assign art_titles = 'Why 660nm and 850nm outperform every other light therapy wavelength.|The 2018 Harvard study that changed at-home hair regrowth forever.|How red light triggers collagen production at the cellular level.|3,000+ peer-reviewed studies: what they actually found.' | split: '|' -%}
  {%- assign art_categories = 'WAVELENGTHS,HAIR LOSS,SKIN,CLINICAL TRIALS' | split: ',' -%}

  <section class="lf-related">
    <div class="lf-related-inner">
      <p class="lf-related-eyebrow">CONTINUE READING</p>
      <h2 class="lf-related-heading">Related science</h2>
      <div class="lf-related-grid">
        {%- for h in art_handles -%}
          {%- if h != current_handle -%}
            <a href="/pages/{{ h }}" class="lf-related-card">
              <span class="lf-related-category">{{ art_categories[forloop.index0] }}</span>
              <span class="lf-related-title">{{ art_titles[forloop.index0] }}</span>
              <span class="lf-related-more">Read article →</span>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>
</article>

{%- stylesheet -%}
.lf { background: var(--cream); color: var(--ink); }

/* Hero band */
.lf-hero { background: #0A0A0A; color: var(--cream); padding: 80px 1.25rem; }
@media (max-width: 768px) { .lf-hero { padding: 56px 1.25rem; } }
.lf-hero-inner { max-width: 720px; margin: 0 auto; text-align: center; }
.lf-eyebrow { display: inline-block; background: var(--red); color: #fff; font-size: 11px; letter-spacing: .22em; text-transform: uppercase; font-weight: 700; padding: .35rem .85rem; border-radius: 999px; margin-bottom: 1.5rem; }
.lf-title { font-family: var(--display); font-size: 48px; line-height: 1.12; letter-spacing: -0.015em; color: var(--cream); margin: 0 0 1.25rem; font-weight: 600; }
@media (max-width: 768px) { .lf-title { font-size: 32px; } }
.lf-subtitle { color: rgba(249,247,244,.72); font-size: 1.125rem; line-height: 1.6; margin: 0 0 1.5rem; }
.lf-meta { color: rgba(249,247,244,.5); font-size: 13px; letter-spacing: .08em; margin: 0; }

/* Body band */
.lf-body { background: var(--cream); padding: 80px 1.25rem; }
@media (max-width: 768px) { .lf-body { padding: 56px 1.25rem; } }
.lf-body-inner { max-width: 720px; margin: 0 auto; font-size: 18px; line-height: 1.8; color: var(--ink); }
.lf-p { color: var(--mid); margin-bottom: 1.5rem; }
.lf-p p { margin: 0 0 1rem; }
.lf-p p:last-child { margin-bottom: 0; }
.lf-p strong { color: var(--ink); }
.lf-p em { color: var(--ink); font-style: italic; }
.lf-p a { color: var(--red); text-decoration: underline; text-underline-offset: 3px; }

.lf-h2 { font-family: var(--display); font-size: 28px; line-height: 1.25; margin: 3rem 0 1.5rem; padding-left: 16px; border-left: 3px solid var(--red); color: var(--ink); font-weight: 600; }
@media (max-width: 768px) { .lf-h2 { font-size: 24px; } }

.lf-quote { margin: 60px 0; padding: 32px 0; border-top: 1px solid var(--gold); border-bottom: 1px solid var(--gold); text-align: center; color: var(--ink); font-family: var(--display); font-size: 24px; line-height: 1.4; font-style: italic; font-weight: 500; }
@media (max-width: 768px) { .lf-quote { font-size: 20px; padding: 24px 0; margin: 40px 0; } }
.lf-quote p { margin: 0; }
.lf-quote cite { display: block; margin-top: 1rem; font-family: var(--sans); font-size: 13px; font-style: normal; color: var(--mid); letter-spacing: .04em; }

.lf-stats { display: grid; grid-template-columns: 1fr; gap: 1.5rem; margin: 2.5rem 0; padding: 2rem 0; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); text-align: center; }
@media (min-width: 640px) { .lf-stats { grid-template-columns: repeat(3, 1fr); } }
.lf-stat-n { font-family: var(--display); font-size: 2.25rem; color: var(--red); line-height: 1.1; font-weight: 700; }
.lf-stat-l { margin: .4rem 0 0; color: var(--mid); font-size: 14px; line-height: 1.45; }

.lf-callout { margin: 2.5rem 0; padding: 24px; background: color-mix(in srgb, var(--cream) 80%, var(--gold) 20%); border-left: 4px solid var(--red); border-radius: 4px; }
.lf-callout-title { font-family: var(--display); font-size: 1.125rem; font-weight: 600; margin: 0 0 .5rem; color: var(--ink); }
.lf-callout-body { color: var(--mid); font-size: 16px; line-height: 1.7; }
.lf-callout-body p { margin: 0; }

.lf-citation { font-size: 13px; color: #8a8a8a; font-style: italic; margin: .5rem 0 2rem; letter-spacing: .02em; }

/* End CTA card */
.lf-cta-card { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin: 3rem 0 0; padding: 1.75rem 2rem; background: var(--cream); border: 2px solid var(--gold); color: var(--ink); text-decoration: none; transition: transform .2s ease, box-shadow .2s ease, background .2s ease; border-radius: 6px; }
.lf-cta-card:hover { transform: translateY(-2px); box-shadow: 0 14px 30px -12px rgba(201,168,76,.35); background: color-mix(in srgb, var(--cream) 92%, var(--gold) 8%); }
.lf-cta-text { font-family: var(--display); font-size: 1.25rem; line-height: 1.3; }
.lf-cta-arrow { font-family: var(--display); font-size: 1.75rem; color: var(--red); flex-shrink: 0; }

/* Related */
.lf-related { background: var(--ink); color: var(--cream); padding: 72px 1.25rem; }
.lf-related-inner { max-width: 1100px; margin: 0 auto; }
.lf-related-eyebrow { color: var(--gold); font-size: 11px; letter-spacing: .22em; text-transform: uppercase; font-weight: 600; margin: 0 0 .75rem; }
.lf-related-heading { font-family: var(--display); font-size: clamp(1.75rem, 3vw, 2.25rem); color: var(--cream); margin: 0 0 2rem; letter-spacing: -0.01em; }
.lf-related-grid { display: grid; grid-template-columns: 1fr; gap: 1rem; }
@media (min-width: 768px) { .lf-related-grid { grid-template-columns: repeat(3, 1fr); gap: 1.25rem; } }
.lf-related-card { display: flex; flex-direction: column; gap: .75rem; padding: 1.5rem; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.1); border-radius: 6px; color: var(--cream); text-decoration: none; transition: background .2s ease, border-color .2s ease, transform .2s ease; }
.lf-related-card:hover { background: rgba(255,255,255,.08); border-color: var(--gold); transform: translateY(-2px); }
.lf-related-category { color: var(--red); font-size: 11px; letter-spacing: .22em; text-transform: uppercase; font-weight: 700; }
.lf-related-title { font-family: var(--display); font-size: 1.125rem; line-height: 1.3; flex: 1; }
.lf-related-more { font-size: 13px; letter-spacing: .08em; color: rgba(249,247,244,.65); font-weight: 500; }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Article Longform",
  "settings": [
    { "type": "text", "id": "category", "label": "Category tag" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Article heading" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle / standfirst" },
    { "type": "text", "id": "meta_label", "label": "Meta line", "default": "8 min read · Lumisca Science Team" },
    { "type": "text", "id": "handle", "label": "Page handle (auto-detected)" },
    { "type": "text", "id": "cta_label", "label": "End-of-article CTA label", "default": "See the science in action — Shop Lumisca" },
    { "type": "url", "id": "cta_url", "label": "End-of-article CTA URL" }
  ],
  "blocks": [
    { "type": "paragraph", "name": "Paragraph", "settings": [
      { "type": "richtext", "id": "body", "label": "Body" }
    ] },
    { "type": "subheading", "name": "Subheading", "settings": [
      { "type": "text", "id": "text", "label": "Text" }
    ] },
    { "type": "pull_quote", "name": "Pull quote", "settings": [
      { "type": "text", "id": "quote", "label": "Quote" },
      { "type": "text", "id": "attribution", "label": "Attribution" }
    ] },
    { "type": "stat_block", "name": "Stat block (3 stats)", "settings": [
      { "type": "text", "id": "stat1_value", "label": "Stat 1 value" },
      { "type": "text", "id": "stat1_label", "label": "Stat 1 label" },
      { "type": "text", "id": "stat2_value", "label": "Stat 2 value" },
      { "type": "text", "id": "stat2_label", "label": "Stat 2 label" },
      { "type": "text", "id": "stat3_value", "label": "Stat 3 value" },
      { "type": "text", "id": "stat3_label", "label": "Stat 3 label" }
    ] },
    { "type": "callout", "name": "Callout box", "settings": [
      { "type": "text", "id": "title", "label": "Title", "default": "Key takeaway" },
      { "type": "richtext", "id": "body", "label": "Body" }
    ] },
    { "type": "citation", "name": "Citation", "settings": [
      { "type": "text", "id": "text", "label": "Citation text" }
    ] }
  ],
  "presets": [ { "name": "Article Longform" } ]
}
{% endschema %}
