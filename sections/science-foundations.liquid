<section class="section-lg science-foundations">
  <div class="container" style="max-width: 56rem;">
    <div style="margin-bottom: 3.5rem;">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="display-lg" style="margin-bottom:1.25rem;">{{ section.settings.heading }}</h2>
      <div class="prose">{{ section.settings.body }}</div>
    </div>

    <div class="grid grid-md-2 sf-wave">
      <div class="sf-card">
        <div class="eyebrow" style="color: var(--red);">{{ section.settings.band1_eyebrow }}</div>
        <h3 class="sf-value">{{ section.settings.band1_value }}</h3>
        <p class="muted" style="line-height:1.65;">{{ section.settings.band1_body }}</p>
      </div>
      <div class="sf-card sf-card-dark">
        <div class="eyebrow" style="color: var(--gold);">{{ section.settings.band2_eyebrow }}</div>
        <h3 class="sf-value" style="color:#fff;">{{ section.settings.band2_value }}</h3>
        <p style="color: rgba(255,255,255,.7); line-height:1.65;">{{ section.settings.band2_body }}</p>
      </div>
    </div>

    <div class="science-deep">
      {%- for block in section.blocks -%}
        <div {{ block.shopify_attributes }}>
          <h3 class="science-deep-title">{{ block.settings.title }}</h3>
          <p class="muted" style="font-size: 17px; line-height: 1.7;">{{ block.settings.body }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- stylesheet -%}
.prose { color: var(--mid); line-height: 1.75; font-size: 17px; }
.prose p + p { margin-top: 1.25rem; }
.sf-wave { margin-bottom: 4rem; }
.sf-card { padding: 2rem; background: #fff; border: 1px solid var(--line); }
@media (min-width: 768px) { .sf-card { padding: 2.5rem; } }
.sf-card-dark { background: var(--ink); color: var(--cream); border-color: var(--ink); }
.sf-value { font-family: var(--display); font-size: 1.875rem; margin-bottom: .75rem; }
.science-deep { display: flex; flex-direction: column; gap: 3.5rem; }
.science-deep-title { font-family: var(--display); font-size: clamp(1.5rem, 3vw, 2rem); margin-bottom: 1rem; }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Science Foundations",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Foundations"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What is red light therapy?"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Red light therapy — also called low-level light therapy (LLLT) and photobiomodulation (PBM) — is the therapeutic use of specific wavelengths of red (630-660nm) and near-infrared (810-850nm) light.</p><p>It's been used in dermatology and sports medicine for over two decades. It does not produce heat. It is not UV. It is not a laser.</p><p>At the cellular level, these wavelengths are absorbed by cytochrome c oxidase in the mitochondria, triggering a measurable increase in ATP production.</p>"
    },
    {
      "type": "text",
      "id": "band1_eyebrow",
      "label": "Band 1 eyebrow",
      "default": "Visible Red"
    },
    {
      "type": "text",
      "id": "band1_value",
      "label": "Band 1 value",
      "default": "650nm"
    },
    {
      "type": "textarea",
      "id": "band1_body",
      "label": "Band 1 body",
      "default": "Penetrates 1-5mm into skin and scalp. Primary wavelength for hair follicle stimulation and surface-level skin outcomes: collagen, elastin, pigmentation."
    },
    {
      "type": "text",
      "id": "band2_eyebrow",
      "label": "Band 2 eyebrow",
      "default": "Near-Infrared"
    },
    {
      "type": "text",
      "id": "band2_value",
      "label": "Band 2 value",
      "default": "850nm"
    },
    {
      "type": "textarea",
      "id": "band2_body",
      "label": "Band 2 body",
      "default": "Penetrates 5-20mm — deep tissue. Ideal for inflammation, cellular repair and reaching follicles below the skin surface."
    }
  ],
  "blocks": [
    {
      "type": "section",
      "name": "Deep dive",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Science Foundations"
    }
  ]
}
{% endschema %}
