<section class="section-dark collection-hero" style="position:relative; overflow:hidden;">
  <div class="hero-glow" style="opacity:.8;"></div>
  <div class="container center" style="position:relative; padding: 4rem 1rem;">
    <p class="eyebrow">Shop</p>
    <h1 class="display-xl" style="margin-bottom:1.25rem;">{{ section.settings.heading | default: collection.title }}</h1>
    <p class="muted" style="max-width: 38rem; margin: 0 auto; line-height: 1.65;">{{ section.settings.body }}</p>
  </div>
</section>

<section class="collection-body">
  <div class="container collection-bar" data-filters>
    <div class="collection-filters no-scrollbar">
      <button type="button" class="chip is-active" data-filter="all">{{ 'collection.filter_all' | t }}</button>
      <button type="button" class="chip" data-filter="hair">{{ 'collection.filter_hair' | t }}</button>
      <button type="button" class="chip" data-filter="face">{{ 'collection.filter_face' | t }}</button>
      <button type="button" class="chip" data-filter="eye">{{ 'collection.filter_eye' | t }}</button>
      <button type="button" class="chip" data-filter="bundle">{{ 'collection.filter_bundle' | t }}</button>
    </div>
    <label class="collection-sort">
      <span class="eyebrow" style="color: var(--mid);">{{ 'collection.sort_by' | t }}</span>
      <select data-sort>
        <option value="featured">{{ 'collection.sort_featured' | t }}</option>
        <option value="price-asc">{{ 'collection.sort_price_asc' | t }}</option>
        <option value="price-desc">{{ 'collection.sort_price_desc' | t }}</option>
        <option value="rating">{{ 'collection.sort_rating' | t }}</option>
      </select>
    </label>
  </div>

  <div class="container section">
    <div class="grid grid-sm-2 grid-lg-4" data-collection-grid>
      {%- for product in collection.products -%}
        {% render 'product-card', product: product %}
      {%- endfor -%}
      {%- if collection.products.size == 0 -%}
        <p class="muted center" style="grid-column: 1/-1;">No products in this collection yet.</p>
      {%- endif -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <nav class="collection-pagination" aria-label="Pagination">
        {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">← Previous</a>{%- endif -%}
        {%- if paginate.next -%}<a href="{{ paginate.next.url }}">Next →</a>{%- endif -%}
      </nav>
    {%- endif -%}
  </div>
</section>

{%- stylesheet -%}
.collection-bar { display: flex; flex-direction: column; gap: 1rem; padding: 1.25rem 1rem; border-bottom: 1px solid var(--line); }
@media (min-width: 768px) { .collection-bar { flex-direction: row; align-items: center; justify-content: space-between; padding: 1.5rem 1rem; } }
.collection-filters { display: flex; gap: .5rem; overflow-x: auto; margin: 0 -.25rem; padding: 0 .25rem; }
.chip { height: 40px; padding: 0 1.25rem; font-size: 12px; letter-spacing: .12em; text-transform: uppercase; font-weight: 500; white-space: nowrap; border: 1px solid var(--line); transition: background .2s, color .2s, border-color .2s; }
.chip.is-active { background: var(--ink); color: var(--cream); border-color: var(--ink); }
.chip:hover:not(.is-active) { border-color: var(--ink); }
.collection-sort { display: flex; align-items: center; gap: .75rem; }
.collection-sort select { height: 40px; padding: 0 .75rem; background: var(--cream); border: 1px solid var(--line); font-size: 14px; }
.collection-pagination { margin-top: 2.5rem; display: flex; justify-content: space-between; gap: 1rem; font-size: 13px; letter-spacing: .15em; text-transform: uppercase; font-weight: 500; }

/* Mobile: force a 2-column grid and stop the 1:1 crop from clipping non-square admin images. */
.collection-body [data-collection-grid] { grid-template-columns: repeat(2, 1fr); gap: .75rem 1rem; }
@media (min-width: 640px) { .collection-body [data-collection-grid] { gap: 1.25rem; } }
.collection-body .card-media { background: #fafafa; }
.collection-body .card-media img { object-fit: contain; }
@media (min-width: 768px) { .collection-body .card-media img { object-fit: cover; } }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Collection Main",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading override" },
    { "type": "textarea", "id": "body", "label": "Intro body", "default": "Four devices. Three routines. One complete at-home light therapy clinic. All clinically calibrated. All free-shipped across the UK. All 60-day guaranteed." }
  ]
}
{% endschema %}
