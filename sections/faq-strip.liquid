<section class="section-lg faq-strip" style="border-top: 1px solid var(--line);">
  <div class="container" style="max-width: 56rem;">
    <div class="center" style="margin-bottom: 2.5rem;">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="display-lg">{{ section.settings.heading }}</h2>
    </div>
    <div class="accordion">
      {%- for block in section.blocks -%}
        <div class="accordion-item" {{ block.shopify_attributes }}>
          <button class="accordion-trigger" type="button" aria-expanded="false">
            {{ block.settings.question }}
            <span class="accordion-icon">{% render 'icon-plus' %}</span>
          </button>
          <div class="accordion-panel">{{ block.settings.answer }}</div>
        </div>
      {%- endfor -%}
    </div>
    {%- if section.settings.cta_label != blank -%}
      <div class="center" style="margin-top: 2.5rem;">
        <a href="{{ section.settings.cta_url }}" class="faq-more">{{ section.settings.cta_label }} {% render 'icon-arrow-right' %}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{%- stylesheet -%}
.faq-more { display: inline-flex; align-items: center; gap: .5rem; font-size: 13px; letter-spacing: .15em; text-transform: uppercase; font-weight: 500; }
.faq-more:hover { color: var(--red); }
{%- endstylesheet -%}

{% schema %}
{
  "name": "FAQ Strip",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "FAQ"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Questions, answered."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "View Full FAQ"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "FAQ Strip",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "How long until I see results?",
            "answer": "<p>Sleep: from night one. Skin: from week 4. Hair regrowth: week 8-12. Consistency matters — 4-5 sessions per week.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Is red light therapy safe?",
            "answer": "<p>Yes. Non-invasive, non-thermal, non-UV. Clinically studied in dermatology for over 20 years. Every Lumisca device is CE-certified.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "How often should I use it?",
            "answer": "<p>4-5 sessions per week is the clinical sweet spot. Each session is 15-25 minutes with auto-shutoff.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "What's in the box?",
            "answer": "<p>The device, USB-C charging cable, premium storage pouch and illustrated user guide. Bundles include a branded gift box and welcome card.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
