<section class="section-lg testimonials">
  <div class="container">
    <div class="center testimonials-head">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="display-lg" style="margin-bottom:1rem;">{{ section.settings.heading }}</h2>
      <div class="testimonials-avg">
        {% render 'star-rating', rating: 5, size: 'lg' %}
        <span><strong>4.9/5</strong> <span class="muted">from {{ section.settings.review_count }} verified reviews</span></span>
      </div>
    </div>

    <div class="grid grid-md-2 grid-lg-3">
      {%- for block in section.blocks -%}
        <article class="t-card" {{ block.shopify_attributes }}>
          {% render 'star-rating', rating: 5, size: 'sm' %}
          <p class="t-body">“{{ block.settings.body }}”</p>
          <div class="t-meta">
            <p class="t-name">{{ block.settings.name }}</p>
            <p class="muted" style="font-size:13px;">
              {{ block.settings.location }} · <span style="color:var(--red);">{{ block.settings.product }}</span>
            </p>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- stylesheet -%}
.testimonials-head { margin-bottom: 3rem; }
.testimonials-avg { display: inline-flex; align-items: center; gap: .75rem; margin-top: 1rem; }
.t-card { background: #fff; border: 1px solid var(--line); padding: 1.5rem; display: flex; flex-direction: column; }
@media (min-width: 768px) { .t-card { padding: 2rem; } }
.t-body { margin-top: 1rem; line-height: 1.7; flex: 1; color: rgba(10,10,10,.9); }
.t-meta { margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--line); }
.t-name { font-weight: 600; }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Reviews"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Are Saying"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review count text",
      "default": "2,847"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Sarah M."
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "default": "Manchester"
        },
        {
          "type": "text",
          "id": "product",
          "label": "Product",
          "default": "Pro Hair Growth Cap"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Review body",
          "default": "10 weeks with the Lumisca cap and I genuinely can't believe the difference."
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "name": "Sarah M.",
            "location": "Manchester",
            "product": "Pro Hair Growth Cap",
            "body": "10 weeks with the Lumisca cap and I genuinely can't believe the difference. My hairdresser noticed before I even told her."
          }
        },
        {
          "type": "review",
          "settings": {
            "name": "Claire B.",
            "location": "Edinburgh",
            "product": "Glow Face Mask",
            "body": "I was spending £80 a month on facials. This paid for itself in the first month. My skin looks brighter after 6 weeks."
          }
        },
        {
          "type": "review",
          "settings": {
            "name": "James T.",
            "location": "Birmingham",
            "product": "Rest Eye Mask",
            "body": "15 minutes before bed and I sleep better than I have in years."
          }
        }
      ]
    }
  ]
}
{% endschema %}
