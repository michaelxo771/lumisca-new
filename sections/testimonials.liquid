<section class="section-lg testimonials">
  <div class="container">
    <div class="center testimonials-head">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="display-lg" style="margin-bottom:1rem;">{{ section.settings.heading }}</h2>
      <div class="testimonials-avg">
        {% render 'star-rating', rating: 5, size: 'lg' %}
        <span><strong>4.9/5</strong> <span class="muted">from {{ section.settings.review_count }} verified reviews</span></span>
      </div>
    </div>

    <div class="grid grid-md-2 grid-lg-3">
      {%- for block in section.blocks -%}
        <article class="t-card" {{ block.shopify_attributes }}>
          {% render 'star-rating', rating: 5, size: 'sm' %}
          <p class="t-body">“{{ block.settings.body }}”</p>
          <div class="t-meta">
            {%- if block.settings.thumb_filename != blank -%}
              <img class="t-thumb" src="{{ block.settings.thumb_filename | asset_url }}" alt="{{ block.settings.product | escape }}" loading="lazy" width="60" height="60">
            {%- else -%}
              <div class="t-thumb t-thumb-placeholder"></div>
            {%- endif -%}
            <div class="t-meta-body">
              <p class="t-name">{{ block.settings.name }}</p>
              <p class="muted t-sub">
                {{ block.settings.location }} · <span style="color:var(--red);">{{ block.settings.product }}</span>
              </p>
            </div>
          </div>
        </article>
      {%- endfor -%}
    </div>

    {%- if section.settings.reviews_cta_label != blank -%}
      <div class="center testimonials-cta">
        <a href="{{ section.settings.reviews_cta_url | default: '/pages/reviews' }}" class="testimonials-cta-link">
          {{ section.settings.reviews_cta_label }} →
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{%- stylesheet -%}
.testimonials-head { margin-bottom: 3rem; }
.testimonials-avg { display: inline-flex; align-items: center; gap: .75rem; margin-top: 1rem; }
.t-card { background: #fff; border: 1px solid var(--line); padding: 1.5rem; display: flex; flex-direction: column; }
@media (min-width: 768px) { .t-card { padding: 2rem; } }
.t-body { margin-top: 1rem; line-height: 1.7; flex: 1; color: rgba(10,10,10,.9); }
.t-meta { margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--line); display: flex; align-items: center; gap: .875rem; }
.t-thumb { width: 60px; height: 60px; border-radius: 50%; object-fit: cover; flex-shrink: 0; background: var(--line); }
.t-thumb-placeholder { background: var(--line); }
.t-meta-body { min-width: 0; flex: 1; }
.t-name { font-weight: 600; }
.t-sub { font-size: 13px; }
.testimonials-cta { margin-top: 2.5rem; }
.testimonials-cta-link { display: inline-flex; align-items: center; gap: .5rem; font-size: 14px; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; color: var(--ink); border-bottom: 1px solid var(--ink); padding-bottom: .25rem; transition: color .2s, border-color .2s; }
.testimonials-cta-link:hover { color: var(--red); border-bottom-color: var(--red); }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Reviews" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Our Customers Are Saying" },
    { "type": "text", "id": "review_count", "label": "Review count text", "default": "2,847" },
    { "type": "text", "id": "reviews_cta_label", "label": "Reviews CTA label", "default": "Read 2,847 verified reviews" },
    { "type": "url", "id": "reviews_cta_url", "label": "Reviews CTA URL" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "Sarah M." },
        { "type": "text", "id": "location", "label": "Location", "default": "Manchester" },
        { "type": "text", "id": "product", "label": "Product", "default": "Pro Hair Growth Cap" },
        { "type": "text", "id": "thumb_filename", "label": "Product thumb asset filename", "default": "product-cap-solo.png" },
        { "type": "textarea", "id": "body", "label": "Review body", "default": "10 weeks with the Lumisca cap and I genuinely can't believe the difference." }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "review", "settings": { "name": "Sarah M.",  "location": "Manchester",  "product": "Pro Hair Growth Cap", "thumb_filename": "product-cap-solo.png",      "body": "10 weeks with the Lumisca cap and I genuinely can't believe the difference. My hairdresser noticed before I even told her." } },
        { "type": "review", "settings": { "name": "Claire B.", "location": "Edinburgh",   "product": "Glow Face Mask",      "thumb_filename": "product-mask-solo.png",     "body": "I was spending £80 a month on facials. This paid for itself in the first month. My skin looks brighter after 6 weeks." } },
        { "type": "review", "settings": { "name": "James T.",  "location": "Birmingham",  "product": "Rest Eye Mask",       "thumb_filename": "product-eye-mask-solo.png", "body": "15 minutes before bed and I sleep better than I have in years." } },
        { "type": "review", "settings": { "name": "Emma R.",   "location": "Dublin",      "product": "Pro Hair Growth Cap", "thumb_filename": "product-cap-solo.png",      "body": "I was skeptical, but after 8 weeks my hair is visibly thicker. My hairdresser actually asked what I was doing differently." } },
        { "type": "review", "settings": { "name": "Priya S.",  "location": "Manchester",  "product": "Glow Face Mask",      "thumb_filename": "product-mask-solo.png",     "body": "I've tried every anti-aging cream on the market. Nothing comes close to this mask. My skin looks lit from within." } },
        { "type": "review", "settings": { "name": "Rachel T.", "location": "Edinburgh",   "product": "Complete Bundle",     "thumb_filename": "product-duo-side.png",      "body": "I bought the bundle after my friend swore by it. Six weeks in, my skin is glowing, my hair feels fuller, and I sleep like a baby." } }
      ]
    }
  ]
}
{% endschema %}
