{%- comment -%}
  Single site-wide announcement bar, rendered from layout/theme.liquid above
  the header. The visual variant is gated by the audience class on <html>
  (set by the head-script in layout/theme.liquid from the CURRENT URL's
  ?audience=women|men param — no cookie / no carryover). Each variant has a
  one-line static message; no rotation, no marquee — copy must fit a single
  ~100-char line. Mike edits all three lines from Theme Customizer.
{%- endcomment -%}

<aside class="ann" data-ann role="region" aria-label="Site announcement">
  <div class="container ann-inner">
    <p class="ann-msg ann-generic">{{ section.settings.generic_text }}</p>
    {%- if section.settings.audience_women_text != blank -%}
      <p class="ann-msg ann-audience" data-ann-audience="women">{{ section.settings.audience_women_text }}</p>
    {%- endif -%}
    {%- if section.settings.audience_men_text != blank -%}
      <p class="ann-msg ann-audience" data-ann-audience="men">{{ section.settings.audience_men_text }}</p>
    {%- endif -%}
  </div>
</aside>

{%- stylesheet -%}
/* Default (generic / no audience class) — cream/gold brand palette. The
   audience-women / audience-men palette overrides live in
   assets/audience-variants.css so all per-variant tone-shifts are in one place. */
.ann { background: var(--cream, #F9F7F4); color: var(--ink, #0A0A0A); border-bottom: 1px solid rgba(184, 146, 78, 0.18); transition: background .25s, color .25s; }
.ann-inner { display: flex; align-items: center; justify-content: center; min-height: 40px; padding: .55rem 1rem; }
.ann-msg { margin: 0; font-size: 12px; letter-spacing: .12em; text-transform: uppercase; font-weight: 500; line-height: 1.35; text-align: center; }
@media (min-width: 768px) { .ann-msg { font-size: 13px; white-space: nowrap; } }
.ann-msg strong { color: var(--gold, #C9A84C); font-weight: 700; letter-spacing: .04em; }

/* Audience variants are hidden by default; revealed via the <html> class
   (see audience-variants.css). Keep the generic visible by default. */
.ann-audience { display: none; }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "aside",
  "class": "announcement-section",
  "settings": [
    {
      "type": "header",
      "content": "Announcement copy"
    },
    {
      "type": "paragraph",
      "content": "One static line per visitor segment. Keep each under ~100 characters so it fits without wrapping on desktop. The audience messages render only when the visitor lands with ?audience=women or ?audience=men in the URL (no cookie persistence — each page evaluates fresh)."
    },
    {
      "type": "text",
      "id": "generic_text",
      "label": "Default message (everyone)",
      "default": "🎁 UK Spring Launch — £90 off the Pro Red Light Cap with code SAVE90"
    },
    {
      "type": "text",
      "id": "audience_women_text",
      "label": "Women's audience message",
      "default": "✨ UK Spring Launch — £90 off with code SAVE90 — designed for women's thinning"
    },
    {
      "type": "text",
      "id": "audience_men_text",
      "label": "Men's audience message",
      "default": "🎯 UK Spring Launch — £90 off with code SAVE90 — for receding & crown thinning"
    }
  ],
  "presets": [
    { "name": "Announcement Bar" }
  ]
}
{% endschema %}
