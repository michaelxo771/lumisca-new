{%- if section.blocks.size > 0 -%}
<div class="announcement" data-announcement>
  <div class="container announcement-inner">
    {%- for block in section.blocks -%}
      <span class="announcement-item{% if forloop.first %} is-active{% endif %}" data-announcement-item {{ block.shopify_attributes }}>
        {{ block.settings.text }}
      </span>
    {%- endfor -%}
  </div>
</div>
{%- endif -%}

{%- stylesheet -%}
.announcement { background: var(--ink); color: var(--cream); font-size: 12px; letter-spacing: .15em; text-transform: uppercase; }
.announcement-inner { height: 40px; display: flex; align-items: center; justify-content: center; position: relative; }
.announcement-item { display: none; text-align: center; font-weight: 500; }
.announcement-item.is-active { display: inline-block; }
@media (min-width: 768px) { .announcement { font-size: 13px; } }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "aside",
  "class": "announcement-section",
  "settings": [],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        { "type": "text", "id": "text", "label": "Message", "default": "🔴 Free UK Delivery On All Orders" }
      ]
    }
  ],
  "max_blocks": 6,
  "default": {
    "blocks": [
      { "type": "message", "settings": { "text": "🔴 Free UK Delivery On All Orders" } },
      { "type": "message", "settings": { "text": "60-Day Money Back Guarantee — Zero Risk" } },
      { "type": "message", "settings": { "text": "Join 10,000+ Lumisca Customers Across The UK" } }
    ]
  }
}
{% endschema %}
