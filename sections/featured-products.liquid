<section class="section-lg featured">
  <div class="container">
    <div class="featured-head">
      <div>
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="display-lg">{{ section.settings.heading }}</h2>
      </div>
      <p class="muted featured-lead">{{ section.settings.lead }}</p>
    </div>
    {%- liquid
      assign rendered_count = 0
      assign collection_handle = section.settings.collection | default: 'all'
      assign fallback = collections[collection_handle]
      if fallback == blank or fallback.products.size == 0
        assign fallback = collections.all
      endif
    -%}

    <div class="grid grid-sm-2 grid-lg-4">
      {%- for block in section.blocks -%}
        {%- assign product = all_products[block.settings.product] -%}
        {%- if product != blank and product != empty -%}
          <div {{ block.shopify_attributes }}>
            {% render 'product-card', product: product %}
          </div>
          {%- assign rendered_count = rendered_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if rendered_count == 0 and fallback.products.size > 0 -%}
        {%- for product in fallback.products limit: 4 -%}
          {% render 'product-card', product: product %}
          {%- assign rendered_count = rendered_count | plus: 1 -%}
        {%- endfor -%}
      {%- endif -%}

      {%- if rendered_count == 0 -%}
        {%- for i in (1..3) -%}
          <article class="card card-placeholder">
            <div class="card-media card-media-ph">
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
            <div class="card-body">
              <h3 class="card-title">Lumisca device {{ i }}</h3>
              <p class="card-tagline muted">Add products to your store to populate this grid automatically.</p>
              <a href="/collections/all" class="btn btn-dark btn-block card-cta">Shop Now</a>
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{%- stylesheet -%}
.featured-head { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2.5rem; }
@media (min-width: 768px) { .featured-head { flex-direction: row; align-items: flex-end; justify-content: space-between; margin-bottom: 3.5rem; } }
.featured-lead { max-width: 26rem; line-height: 1.65; }
.card-media-ph { aspect-ratio: 4/5; background: var(--line); display: flex; align-items: center; justify-content: center; }
.card-media-ph svg { width: 70%; height: 70%; fill: rgba(10,10,10,.18); }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Lumisca Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Clinic-grade devices, designed for your sofa."
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Lead text",
      "default": "Three devices that cover hair, skin and sleep — or bundle them together and save over £174."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Fallback collection"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Featured Products",
      "category": "Products",
      "settings": {
        "collection": "all"
      }
    }
  ]
}
{% endschema %}
