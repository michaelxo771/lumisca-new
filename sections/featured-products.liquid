        { "type": "card", "settings": { "image_filename": "product-eye-mask-solo.png", "title": "Rest Heated Eye Mask", "tagline": "Deeper sleep in 10 minutes", "price": 2999, "compare_at_price": 0, "rating": "4.8", "review_count": "734 reviews", "is_featured": false } },
        { "type": "card", "settings": { "image_filename": "product-duo-side.png", "title": "The Complete Lumisca Bundle", "tagline": "All three devices — hair, skin, sleep", "price": 12499, "compare_at_price": 14997, "rating": "4.9", "review_count": "2,847 reviews", "is_featured": true } }
      ]
    }
  ]
}
{% endschema %}
