<section class="section-lg featured-v2">
  <div class="container">
    <div class="featured-v2-head">
      <div>
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="display-lg">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.lead != blank -%}
        <p class="muted featured-v2-lead">{{ section.settings.lead }}</p>
      {%- endif -%}
    </div>

    <div class="featured-v2-grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign img = block.settings.image_filename | default: ''
          assign href = block.settings.url | default: '#'
          assign is_featured = block.settings.is_featured
          assign saved = 0
          if block.settings.compare_at_price > 0 and block.settings.compare_at_price > block.settings.price
            assign saved = block.settings.compare_at_price | minus: block.settings.price
          endif
        -%}
        <a href="{{ href }}" class="featured-v2-card{% if is_featured %} featured-v2-card-gold{% endif %}" {{ block.shopify_attributes }}>
          <div class="featured-v2-media">
            {%- if img != blank -%}
              <img src="{{ img | asset_url }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="720" height="900">
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
            {%- if is_featured and saved > 0 -%}
              <span class="featured-v2-badge">SAVE £{{ saved | divided_by: 100.0 }}</span>
            {%- endif -%}
          </div>
          <div class="featured-v2-body">
            <div class="featured-v2-rating">
              {% render 'star-rating', rating: 5, size: 'sm' %}
              <span class="muted">{{ block.settings.rating | default: '4.9' }} ({{ block.settings.review_count | default: '1,284' }})</span>
            </div>
            <h3 class="featured-v2-title">{{ block.settings.title }}</h3>
            <p class="featured-v2-sub muted">{{ block.settings.tagline }}</p>
            <div class="featured-v2-price">
              <span class="price-now">£{{ block.settings.price | divided_by: 100.0 }}</span>
              {%- if block.settings.compare_at_price > 0 and block.settings.compare_at_price > block.settings.price -%}
                <span class="price-was">£{{ block.settings.compare_at_price | divided_by: 100.0 }}</span>
              {%- endif -%}
            </div>
            <span class="btn btn-dark btn-block featured-v2-cta">Shop Now {% render 'icon-arrow-right' %}</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- stylesheet -%}
.featured-v2 { background: var(--cream); }
.featured-v2-head { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 3rem; }
@media (min-width: 768px) { .featured-v2-head { flex-direction: row; align-items: flex-end; justify-content: space-between; } }
.featured-v2-lead { max-width: 26rem; line-height: 1.65; }
.featured-v2-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
@media (min-width: 768px) { .featured-v2-grid { grid-template-columns: 1fr 1fr; gap: 2rem; } }
.featured-v2-card { display: flex; flex-direction: column; background: #fff; border: .5px solid rgba(10,10,10,.1); transition: transform .3s ease, box-shadow .3s ease, border-color .3s ease; color: inherit; }
.featured-v2-card:hover { transform: translateY(-4px); box-shadow: 0 20px 60px -20px rgba(10,10,10,.18); }
.featured-v2-card-gold { border: 2px solid var(--gold); background: color-mix(in srgb, var(--cream) 85%, var(--gold) 15%); }
.featured-v2-media { position: relative; aspect-ratio: 4/5; overflow: hidden; background: #fafafa; }
.featured-v2-media img, .featured-v2-media svg { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .6s ease; }
.featured-v2-card:hover .featured-v2-media img { transform: scale(1.03); }
.featured-v2-badge { position: absolute; top: 1rem; right: 1rem; background: var(--gold); color: var(--ink); font-size: 11px; letter-spacing: .15em; text-transform: uppercase; font-weight: 700; padding: .4rem .75rem; }
.featured-v2-body { padding: 1.5rem; display: flex; flex-direction: column; gap: .5rem; }
@media (min-width: 768px) { .featured-v2-body { padding: 2rem; } }
.featured-v2-rating { display: flex; align-items: center; gap: .5rem; font-size: 13px; }
.featured-v2-title { font-family: var(--display); font-size: clamp(1.25rem, 2.2vw, 1.5rem); line-height: 1.25; }
.featured-v2-sub { font-size: 14px; line-height: 1.5; }
.featured-v2-price { display: flex; align-items: baseline; gap: .75rem; margin: .25rem 0 .5rem; }
.featured-v2-price .price-now { font-family: var(--display); font-size: 1.75rem; }
.featured-v2-price .price-was { color: var(--mid); text-decoration: line-through; font-size: 1rem; }
.featured-v2-cta { margin-top: .75rem; }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Lumisca Collection" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Clinic-grade devices, designed for your sofa." },
    { "type": "textarea", "id": "lead", "label": "Lead", "default": "Three devices that cover hair, skin and sleep — or bundle them together and save over £24." }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Product card",
      "settings": [
        { "type": "text", "id": "image_filename", "label": "Asset filename", "default": "product-cap-solo.png" },
        { "type": "text", "id": "title", "label": "Product title", "default": "Pro Red Light Hair Growth Cap" },
        { "type": "text", "id": "tagline", "label": "Tagline", "default": "Clinic-grade hair regrowth, built into a cap" },
        { "type": "number", "id": "price", "label": "Price in pence", "default": 6499 },
        { "type": "number", "id": "compare_at_price", "label": "Compare-at price in pence", "default": 0 },
        { "type": "text", "id": "rating", "label": "Rating", "default": "4.9" },
        { "type": "text", "id": "review_count", "label": "Review count", "default": "1,284 reviews" },
        { "type": "url", "id": "url", "label": "Product URL" },
        { "type": "checkbox", "id": "is_featured", "label": "Featured (gold border)", "default": false }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Featured Products",
      "category": "Products",
      "blocks": [
        { "type": "card", "settings": { "image_filename": "product-cap-solo.png", "title": "Pro Red Light Hair Growth Cap", "tagline": "Clinic-grade hair regrowth, built into a cap", "price": 6499, "compare_at_price": 0, "rating": "4.9", "review_count": "1,284 reviews", "is_featured": false } },
