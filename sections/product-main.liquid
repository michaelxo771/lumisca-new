<script>
(function () {
  var container = document.querySelector('[data-pvol]');
  if (!container) return;
  if (container.hasAttribute('data-cap-bundle')) return;  /* cap PDP uses the bundle picker IIFE below; existing qty-multiplier doesn't apply */
  var form = document.querySelector('[data-product-form]');
  var qtyInput = form && form.querySelector('input[name=quantity]');
  var total = document.querySelector('[data-atc-total]');
  var sub = document.querySelector('[data-atc-sub]');
  var subTotal = document.querySelector('[data-atc-sub-total]');

  var tier2Pct = parseInt(container.getAttribute('data-tier2-pct') || '15', 10);
  var tier3Pct = parseInt(container.getAttribute('data-tier3-pct') || '23', 10);
  var currentQty = 1;

  function getUnit() {
    return parseInt((form && form.getAttribute('data-unit-pence')) || '0', 10);
  }

  // Pull initial money symbol from the server-rendered ATC total so we match locale.
  var initialText = (total && total.textContent) || '£0.00';
  var symMatch = initialText.match(/^[^\d\-]*/);
  var symbol = (symMatch && symMatch[0]) || '£';

  function fmt(pence) {
    var amt = (pence / 100).toFixed(2);
    return symbol + amt;
  }

  function apply(qty) {
    currentQty = qty || currentQty || 1;
    var unit = getUnit();
    var discountPct = 0;
    if (currentQty === 2) discountPct = tier2Pct;
    else if (currentQty >= 3) discountPct = tier3Pct;

    var preTotal = unit * currentQty;
    var afterTotal = Math.round(preTotal * (100 - discountPct) / 100);

    if (total) total.textContent = fmt(preTotal);
    if (sub && subTotal) {
      if (discountPct > 0) {
        subTotal.textContent = fmt(afterTotal);
        sub.hidden = false;
      } else {
        sub.hidden = true;
      }
    }
  }

  container.addEventListener('click', function (e) {
    var tier = e.target.closest('.pvol-tier');
    if (!tier) return;
    container.querySelectorAll('.pvol-tier').forEach(function (t) { t.classList.remove('is-active'); });
    tier.classList.add('is-active');
    var qty = parseInt(tier.getAttribute('data-pvol-qty'), 10) || 1;
    if (qtyInput) qtyInput.value = qty;
    var radio = tier.querySelector('input[type=radio]');
    if (radio) radio.checked = true;
    apply(qty);
  });

  // Variant picker recomputes prices when the user changes model/plug.
  window.__lumiscaPvolRecalc = function () { apply(currentQty); };

  var initialActive = container.querySelector('.pvol-tier.is-active');
  var initialQty = initialActive ? (parseInt(initialActive.getAttribute('data-pvol-qty'), 10) || 1) : 1;
  apply(initialQty);
})();
</script>

<script>
/* Hair Cap PDP — bundle picker (replaces qty-multiplier). Three tiers:
   cap-only (single SKU add), hair-skin-duo (multi-item: cap + face),
   complete (single SKU add of the existing bundle product). On tier
   click, repaints ATC total + Total Value box + bonus stack footer
   from the tier's data-tv-* attrs. On form submit, intercepts the
   default Cart.add path in capture phase so it can do a multi-item
   POST to /cart/add.js for the duo tier. Skips the sticky-bar form
   so the floating bar still does its simple cap-only add. */
(function () {
  var picker = document.querySelector('[data-cap-bundle]');
  if (!picker) return;

  function fmt(pence) { var amt = (pence / 100).toFixed(2); return '£' + amt; }
  function setText(sel, txt) {
    var els = document.querySelectorAll(sel);
    for (var i = 0; i < els.length; i++) els[i].textContent = txt;
  }

  function applyTier(tier) {
    var rrp = parseInt(tier.getAttribute('data-tv-rrp-pence'), 10) || 0;
    var today = parseInt(tier.getAttribute('data-tv-today-pence'), 10) || 0;
    var save = parseInt(tier.getAttribute('data-tv-save-pence'), 10) || 0;
    var pct = parseInt(tier.getAttribute('data-tv-pct'), 10) || 0;

    setText('[data-cap-tv-strike]', fmt(rrp));
    setText('[data-cap-tv-amount]', fmt(today));
    setText('[data-cap-tv-savings]', fmt(save) + ' (' + pct + '% OFF)');
    setText('[data-cap-bonus-strike]', fmt(rrp));
    setText('[data-cap-bonus-today]', fmt(today));
    setText('[data-atc-total]', fmt(today));

    var tiers = picker.querySelectorAll('.pvol-tier');
    for (var i = 0; i < tiers.length; i++) tiers[i].classList.remove('is-active');
    tier.classList.add('is-active');
    var radio = tier.querySelector('input[type=radio]');
    if (radio) radio.checked = true;
  }

  picker.addEventListener('click', function (e) {
    var tier = e.target.closest('.pvol-tier');
    if (!tier) return;
    applyTier(tier);
  });

  var initial = picker.querySelector('.pvol-tier.is-active');
  if (initial) applyTier(initial);

  /* Capture-phase submit intercept — fires before the document-level
     handler in theme.js so the duo/bundle path can divert from the
     default single-variant Cart.add. Sticky-bar form (.psa-form) is
     left alone: it always adds the cap variant. */
  document.addEventListener('submit', function (e) {
    var form = e.target.closest('[data-product-form]');
    if (!form) return;
    if (form.classList.contains('psa-form')) return;
    e.preventDefault();
    e.stopPropagation();

    var tier = picker.querySelector('.pvol-tier.is-active');
    if (!tier) return;
    var mode = tier.getAttribute('data-add-mode');
    var capV = parseInt(picker.getAttribute('data-cap-variant'), 10) || 0;
    var faceV = parseInt(picker.getAttribute('data-face-variant'), 10) || 0;
    var bundleV = parseInt(picker.getAttribute('data-bundle-variant'), 10) || 0;
    var items = [];
    if (mode === 'cap' && capV) items = [{ id: capV, quantity: 1 }];
    else if (mode === 'cap+face' && capV && faceV) items = [{ id: capV, quantity: 1 }, { id: faceV, quantity: 1 }];
    else if (mode === 'bundle' && bundleV) items = [{ id: bundleV, quantity: 1 }];
    if (items.length === 0) return;

    var btn = form.querySelector('[data-atc-btn]');
    if (btn) { btn.disabled = true; btn.dataset.label = btn.textContent; btn.textContent = 'Adding…'; }

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ items: items })
    }).then(function (r) { return r.json(); })
      .then(function () {
        if (window.LumiscaCart && typeof window.LumiscaCart.fetch === 'function') {
          return window.LumiscaCart.fetch().then(function (cart) {
            window.LumiscaCart.render(cart);
            window.LumiscaCart.open();
          });
        }
      })
      .catch(function (err) { try { console.warn('[lumisca cap-bundle add]', err); } catch (_) {} })
      .then(function () {
        if (btn) { btn.disabled = false; btn.textContent = btn.dataset.label || btn.textContent; }
      });
  }, true);
})();
</script>

<script>
/* Hair Cap PDP — 3-hour rolling offer countdown. localStorage persistence:
   the offer-end timestamp is written once and read on subsequent loads, so
   the timer doesn't reset on page navigation. When it hits zero, a fresh
   3-hour window is minted and the timer continues. Cap-only — markup is
   handle-gated in the section, so this script no-ops on other PDPs.
   IntersectionObserver gates setInterval start until the timer enters the
   viewport (avoids waking up off-screen tabs / lazy-load contexts).
   .is-urgent class added when <30 min remain for visual pulse. */
(function () {
  var el = document.querySelector('[data-cap-timer]');
  if (!el) return;
  var KEY = 'lumisca_cap_offer_end';
  var WINDOW_MS = 3 * 60 * 60 * 1000;
  var URGENT_MS = 30 * 60 * 1000;
  function pad(n) { return String(n).padStart(2, '0'); }
  function freshEnd() {
    var end = Date.now() + WINDOW_MS;
    try { localStorage.setItem(KEY, String(end)); } catch (_) {}
    return end;
  }
  function readEnd() {
    var raw = 0;
    try { raw = parseInt(localStorage.getItem(KEY), 10) || 0; } catch (_) {}
    if (!raw || raw <= Date.now()) return freshEnd();
    return raw;
  }
  var end = readEnd();
  var hEl = el.querySelector('[data-cap-h]');
  var mEl = el.querySelector('[data-cap-m]');
  var sEl = el.querySelector('[data-cap-s]');
  var interval = null;
  function tick() {
    var diff = end - Date.now();
    if (diff <= 0) { end = freshEnd(); diff = end - Date.now(); }
    var h = Math.floor(diff / 3600000);
    var m = Math.floor((diff % 3600000) / 60000);
    var s = Math.floor((diff % 60000) / 1000);
    if (hEl) hEl.textContent = pad(h);
    if (mEl) mEl.textContent = pad(m);
    if (sEl) sEl.textContent = pad(s);
    el.classList.toggle('is-urgent', diff <= URGENT_MS);
  }
  function start() {
    if (interval) return;
    tick();
    interval = setInterval(tick, 1000);
  }
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) { if (e.isIntersecting) { start(); io.disconnect(); } });
    }, { rootMargin: '200px' });
    io.observe(el);
  } else {
    start();
  }
})();
</script>

<script>
/* Cap PDP — audience-targeted hero. Reads ?audience=women|men on load,
   reveals the matching pre-rendered banner above the product rating,
   and (for men) reorders the reviews grid so the first card is a male
   testimonial (Tom W. → Connor S. → Mark P. fallback chain). Default
   (no param, or unknown value) leaves the page exactly as rendered. */
(function () {
  if (document.body.className.indexOf('template-product') === -1) return;
  var audience = '';
  try {
    var params = new URLSearchParams(window.location.search);
    audience = (params.get('audience') || '').toLowerCase();
  } catch (_) { return; }
  if (audience !== 'women' && audience !== 'men') return;

  var banner = document.querySelector('[data-cap-audience="' + audience + '"]');
  if (banner) { banner.hidden = false; banner.classList.add('is-visible'); }

  if (audience === 'men') {
    var grid = document.querySelector('.prev-grid');
    if (!grid) return;
    var maleNames = ['Tom W.', 'Connor S.', 'Mark P.'];
    for (var i = 0; i < maleNames.length; i++) {
      var match = grid.querySelector('[data-review-name="' + maleNames[i] + '"]');
      if (match) { grid.insertBefore(match, grid.firstChild); break; }
    }
  }
})();
</script>

