{%- liquid
  assign rating = product.metafields.reviews.rating | default: 4.9
  assign review_count = product.metafields.reviews.count | default: 0
  assign stock = product.metafields.custom.stock | default: 23
  assign sold_24h = product.metafields.custom.sold_24h | default: 47
  assign viewing_now = product.metafields.custom.viewing_now | default: 12
  assign current_variant = product.selected_or_first_available_variant
  assign handle = product.handle | default: ''
  assign is_bundle = false
  if product.handle == settings.bundle_product_handle
    assign is_bundle = true
  endif
-%}
<section class="section product-section">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/collections/all">Shop</a>
      <span>/</span>
      <span class="muted">{{ product.title | truncate: 40 }}</span>
    </nav>

    <div class="product-grid">
      {%- comment -%} Gallery {%- endcomment -%}
      <div class="product-gallery" data-gallery>
        <div class="product-thumbs no-scrollbar">
          {%- for img in product.images -%}
            <button type="button" class="product-thumb{% if forloop.first %} is-active{% endif %}" data-gallery-thumb="{{ img | image_url: width: 1200 }}" data-gallery-label="{{ img.alt | escape }}" aria-label="View image {{ forloop.index }}">
              <img src="{{ img | image_url: width: 200 }}" alt="{{ img.alt | escape }}" loading="lazy" width="80" height="80">
            </button>
          {%- endfor -%}
          {%- if product.images.size == 0 -%}
            {%- assign labels = "Front,Interior,Lifestyle,Detail" | split: ',' -%}
            {%- for label in labels -%}
              <button type="button" class="product-thumb{% if forloop.first %} is-active{% endif %}" data-gallery-thumb="" data-gallery-label="{{ product.title }} — {{ label }}">
                <div class="ph aspect-square"><span class="ph-label">{{ label }}</span></div>
              </button>
            {%- endfor -%}
          {%- endif -%}
        </div>
        <div class="product-main-img" data-gallery-main>
          {%- if product.featured_image -%}
            <img src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.featured_image.alt | escape }}" loading="eager" width="1200" height="1200">
          {%- else -%}
            <div class="ph aspect-square"><span class="ph-label">{{ product.title }}</span></div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Info {%- endcomment -%}
      <div class="product-info" id="main-atc">
        <div class="product-rating">
          {% render 'star-rating', rating: rating, size: 'md' %}
          <span class="muted" style="font-size:14px;">{{ rating }} {% if review_count > 0 %}({{ review_count | times: 1 | default: 1248 }} reviews){% endif %}</span>
        </div>

        <h1 class="product-title">{{ product.title }}</h1>
        <p class="muted product-desc">{{ product.description | strip_html | truncatewords: 40 }}</p>

        <div class="product-price">
          <span class="product-price-now">{{ product.price | money }}</span>
          {%- if product.compare_at_price > product.price -%}
            <span class="product-price-was">{{ product.compare_at_price | money }}</span>
            {%- assign saved = product.compare_at_price | minus: product.price -%}
            {%- assign saved_pct = saved | times: 100.0 | divided_by: product.compare_at_price | round -%}
            <span class="badge badge-red">Save {{ saved_pct }}% · {{ saved | money }}</span>
          {%- endif -%}
        </div>

        {%- if is_bundle -%}
          <div class="product-bundle-cd">
            <div>
              <p class="eyebrow" style="color: var(--gold);">Offer ends in</p>
              <p class="muted" style="font-size:12px; margin-top: .25rem;">Price increases at midnight</p>
            </div>
            <div class="countdown" data-countdown="daily">
              <div class="countdown-box"><span class="countdown-n" data-cd-h>00</span></div>
              <span class="countdown-sep">:</span>
              <div class="countdown-box"><span class="countdown-n" data-cd-m>00</span></div>
              <span class="countdown-sep">:</span>
              <div class="countdown-box"><span class="countdown-n" data-cd-s>00</span></div>
            </div>
          </div>
        {%- endif -%}

        <div class="product-trust">
          <span>Free UK Delivery</span><span>·</span>
          <span>60-Day Money Back</span><span>·</span>
          <span class="product-trust-hi">In Stock — Ships Today</span>
        </div>

        <ul class="product-scarcity">
          <li class="product-scarcity-red">⚠️ Only {{ stock }} units remaining</li>
          <li>🔥 <strong>{{ sold_24h }} people</strong> bought this in the last 24 hours</li>
          <li class="muted">👁 <strong style="color:var(--ink);">{{ viewing_now }} people</strong> viewing this right now</li>
          <li data-dispatch-text></li>
        </ul>

        {%- comment -%} Volume tiers — bundle has its own pricing so we skip it there {%- endcomment -%}
        {%- liquid
          assign show_tiers = true
          if handle contains 'bundle' or handle contains 'complete'
            assign show_tiers = false
          endif

          assign tier2_pct = section.settings.tier2_discount_pct | default: 15
          assign tier3_pct = section.settings.tier3_discount_pct | default: 23
          assign tier2_factor = 100 | minus: tier2_pct
          assign tier3_factor = 100 | minus: tier3_pct

          assign tier1 = product.price
          assign tier2 = product.price | times: tier2_factor | divided_by: 100 | round
          assign tier3 = product.price | times: tier3_factor | divided_by: 100 | round
        -%}

        {%- if show_tiers -%}
          <div class="pvol" data-pvol data-tier2-pct="{{ tier2_pct }}" data-tier3-pct="{{ tier3_pct }}">
            <p class="eyebrow" style="color: var(--mid);">Choose Your Pack</p>
            <div class="pvol-tiers">
              <label class="pvol-tier" data-pvol-qty="1">
                <input type="radio" name="pvol" value="1">
                <span class="pvol-radio" aria-hidden="true"></span>
                <span class="pvol-body">
                  <span class="pvol-row">
                    <span class="pvol-title">1 DEVICE</span>
                  </span>
                  <span class="pvol-sub"><strong>{{ tier1 | money }}</strong> each · Best for single user</span>
                </span>
              </label>
              <label class="pvol-tier is-active" data-pvol-qty="2">
                <input type="radio" name="pvol" value="2" checked>
                <span class="pvol-radio" aria-hidden="true"></span>
                <span class="pvol-body">
                  <span class="pvol-row">
                    <span class="pvol-title">2 DEVICES — POPULAR</span>
                    <span class="pvol-badge">BEST VALUE</span>
                  </span>
                  <span class="pvol-sub"><strong>{{ tier2 | money }}</strong> each (save {{ tier2_pct }}%) · {{ tier2 | times: 2 | money }} total · Free shipping</span>
                </span>
              </label>
              <label class="pvol-tier" data-pvol-qty="3">
                <input type="radio" name="pvol" value="3">
                <span class="pvol-radio" aria-hidden="true"></span>
                <span class="pvol-body">
                  <span class="pvol-row">
                    <span class="pvol-title">3 DEVICES — MAXIMUM RESULTS</span>
                  </span>
                  <span class="pvol-sub"><strong>{{ tier3 | money }}</strong> each (save {{ tier3_pct }}%) · {{ tier3 | times: 3 | money }} total · Free shipping + priority</span>
                </span>
              </label>
            </div>
            <p class="pvol-fine">✓ Volume savings applied automatically at checkout</p>
          </div>
        {%- endif -%}

        <form data-product-form method="post" action="{{ routes.cart_add_url }}" data-unit-pence="{{ product.price }}">
          <input type="hidden" name="id" value="{{ current_variant.id }}">

          <div class="product-qty-row" data-qty>
            <span class="eyebrow" style="color: var(--mid);">{{ 'product.quantity' | t }}</span>
            <div class="product-qty">
              <button type="button" data-qty-step="-1" aria-label="Decrease">−</button>
              <input type="number" name="quantity" value="{% if show_tiers %}2{% else %}1{% endif %}" min="1" inputmode="numeric">
              <button type="button" data-qty-step="1" aria-label="Increase">+</button>
            </div>
          </div>

          <button type="submit" class="btn btn-red btn-xl btn-block product-atc" data-atc-btn data-main-atc>
            {% if current_variant.available %}{{ 'product.add_to_cart' | t }} · <span data-atc-total>{{ product.price | money }}</span>{% else %}{{ 'product.sold_out' | t }}{% endif %}
            {% render 'icon-arrow-right' %}
          </button>

          {%- if show_tiers -%}
            <p class="product-atc-sub" data-atc-sub hidden>
              after volume discount: <strong data-atc-sub-total></strong> · applied at checkout
            </p>
          {%- endif -%}
        </form>

        <div class="product-pay">
          {%- assign pay_methods = 'Apple Pay,Google Pay,Klarna' | split: ',' -%}
          {%- for pay in pay_methods -%}
            <span class="product-pay-badge">{{ pay }}</span>
          {%- endfor -%}
        </div>

        <ul class="product-trust">
          <li>
            <span class="product-trust-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg></span>
            <span class="product-trust-copy"><strong>Free Tracked Shipping</strong><small>UK + Ireland</small></span>
          </li>
          <li>
            <span class="product-trust-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l8 4v6c0 5-3.5 8-8 10-4.5-2-8-5-8-10V6l8-4z"/><path d="M9 12l2 2 4-4"/></svg></span>
            <span class="product-trust-copy"><strong>60-Day Guarantee</strong><small>Money back, no questions</small></span>
          </li>
          <li>
            <span class="product-trust-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="9" rx="1"/><path d="M8 11V8a4 4 0 018 0v3"/></svg></span>
            <span class="product-trust-copy"><strong>Secure Checkout</strong><small>256-bit SSL encryption</small></span>
          </li>
          <li>
            <span class="product-trust-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="9" r="6"/><path d="M8.5 14l-1.5 7 5-3 5 3-1.5-7"/></svg></span>
            <span class="product-trust-copy"><strong>2-Year Warranty</strong><small>Full device coverage</small></span>
          </li>
        </ul>
      </div>
    </div>

    {%- comment -%} Tabs {%- endcomment -%}
    <div class="product-tabs" data-tabs>
      <div class="product-tabs-nav no-scrollbar">
        {%- assign tabs = 'description,how-to-use,in-the-box,specs,shipping' | split: ',' -%}
        {%- assign tab_labels = 'Description,How To Use,In The Box,Specs,Shipping' | split: ',' -%}
        {%- for t in tabs -%}
          <button type="button" class="product-tab{% if forloop.first %} is-active{% endif %}" data-tab="{{ t }}">{{ tab_labels[forloop.index0] }}</button>
        {%- endfor -%}
      </div>
      <div class="product-tab-body">
        <div data-tab-panel="description" class="product-panel is-active">
          <div class="product-long">{{ product.description }}</div>
          {%- assign benefits = product.metafields.custom.benefits.value -%}
          {%- if benefits -%}
            <ul class="product-benefit-list">
              {%- for b in benefits -%}
                <li>{% render 'icon-check' %} {{ b }}</li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
        <div data-tab-panel="how-to-use" class="product-panel">
          {%- assign steps = product.metafields.custom.how_to_use.value -%}
          {%- if steps -%}
            <ol class="product-howto">
              {%- for step in steps -%}<li><span class="product-howto-n">{{ forloop.index }}</span><span>{{ step }}</span></li>{%- endfor -%}
            </ol>
          {%- else -%}
            <p class="muted">Follow the quick-start guide in the box. Use 4-5 times per week for best results.</p>
          {%- endif -%}
        </div>
        <div data-tab-panel="in-the-box" class="product-panel">
          {%- assign box = product.metafields.custom.in_the_box.value -%}
          {%- if box -%}
            <ul class="product-box">
              {%- for item in box -%}<li><span class="product-box-dot"></span> {{ item }}</li>{%- endfor -%}
            </ul>
          {%- else -%}
            <ul class="product-box">
              <li><span class="product-box-dot"></span> {{ product.title }}</li>
              <li><span class="product-box-dot"></span> USB-C charging cable</li>
              <li><span class="product-box-dot"></span> Premium storage pouch</li>
              <li><span class="product-box-dot"></span> Illustrated user guide</li>
            </ul>
          {%- endif -%}
        </div>
        <div data-tab-panel="specs" class="product-panel">
          {%- assign specs = product.metafields.custom.specs.value -%}
          {%- if specs -%}
            <dl class="product-specs">
              {%- for s in specs -%}
                <div><dt>{{ s.label }}</dt><dd>{{ s.value }}</dd></div>
              {%- endfor -%}
            </dl>
          {%- else -%}
            <p class="muted">Full specs listed on the packaging and included user guide.</p>
          {%- endif -%}
        </div>
        <div data-tab-panel="shipping" class="product-panel">
          <p class="muted"><strong style="color:var(--ink);">Free UK delivery on every order.</strong> Tracked courier, 3-5 working days. Order before 3pm Monday-Friday for same-day dispatch.</p>
          <p class="muted" style="margin-top:1rem;">We also ship to Ireland, Jersey, Guernsey and the Isle of Man. 60-day returns, no questions asked.</p>
        </div>
      </div>
    </div>
  </div>
</section>

{%- stylesheet -%}
.product-section { padding-top: 1.5rem; }
.breadcrumb { font-size: 12px; letter-spacing: .12em; text-transform: uppercase; color: var(--mid); padding: 1rem 0; }
.breadcrumb a:hover { color: var(--ink); }
.breadcrumb span { margin: 0 .5rem; }
.product-grid { display: grid; gap: 2.5rem; padding: 2rem 0; }
@media (min-width: 1024px) { .product-grid { grid-template-columns: 1fr 1fr; gap: 3.5rem; padding: 3rem 0; } }
.product-gallery { display: flex; flex-direction: column-reverse; gap: .75rem; }
@media (min-width: 768px) { .product-gallery { flex-direction: row; } }
.product-thumbs { display: flex; gap: .75rem; overflow-x: auto; }
@media (min-width: 768px) { .product-thumbs { flex-direction: column; width: 80px; overflow: visible; } }
.product-thumb { flex-shrink: 0; width: 80px; border: 2px solid var(--line); transition: border-color .2s; }
.product-thumb.is-active { border-color: var(--red); }
.product-thumb img { width: 80px; height: 80px; object-fit: cover; display: block; }
.product-main-img { flex: 1; position: relative; }
.product-main-img img { width: 100%; aspect-ratio: 1/1; object-fit: cover; display: block; }
.product-info { display: flex; flex-direction: column; gap: 1.25rem; }
#main-atc { scroll-margin-top: 96px; }
.product-rating { display: flex; align-items: center; gap: .5rem; }
.product-title { font-size: clamp(1.75rem, 4vw, 2.5rem); line-height: 1.2; }
.product-desc { font-size: 15px; line-height: 1.65; }
.product-price { display: flex; align-items: baseline; gap: .75rem; flex-wrap: wrap; }
.product-price-now { font-family: var(--display); font-size: 2.25rem; }
.product-price-was { color: var(--mid); text-decoration: line-through; font-size: 1.125rem; }
.product-bundle-cd { background: var(--ink); color: var(--cream); padding: 1rem; display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
.product-bundle-cd .countdown-box { min-width: 52px; padding: .5rem .75rem; }
.product-bundle-cd .countdown-n { font-size: 24px; }
.product-trust { font-size: 12px; letter-spacing: .1em; text-transform: uppercase; color: var(--mid); display: flex; flex-wrap: wrap; gap: .25rem .75rem; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); padding: 1rem 0; }
.product-trust-hi { color: var(--red); font-weight: 600; }
.product-scarcity { display: flex; flex-direction: column; gap: .5rem; font-size: 14px; }
.product-scarcity-red { color: var(--red); font-weight: 500; }
.product-qty-row { padding-top: .5rem; display: flex; flex-direction: column; gap: .75rem; }
.product-qty { display: inline-flex; border: 1px solid var(--line); width: fit-content; }
.product-qty button { width: 48px; height: 48px; font-size: 20px; }
.product-qty input { width: 56px; height: 48px; border: 0; text-align: center; font-variant-numeric: tabular-nums; background: transparent; }
.product-atc { justify-content: center; gap: .5rem; }
.product-pay { display: grid; grid-template-columns: repeat(3, 1fr); gap: .75rem; }
.product-pay-badge { display: inline-flex; align-items: center; justify-content: center; height: 44px; border: 1px solid var(--line); font-size: 12px; letter-spacing: .1em; text-transform: uppercase; font-weight: 600; }

/* Volume tiers */
.pvol { display: flex; flex-direction: column; gap: .75rem; padding-top: .25rem; }
.pvol-tiers { display: flex; flex-direction: column; gap: .6rem; }
.pvol-tier { display: flex; align-items: center; gap: .75rem; padding: 1rem 1.25rem; background: #fff; border: 1.5px solid var(--line); border-radius: 10px; cursor: pointer; position: relative; transition: border-color .15s, background .15s; }
.pvol-tier input { position: absolute; opacity: 0; pointer-events: none; }
.pvol-radio { flex-shrink: 0; width: 20px; height: 20px; border-radius: 50%; border: 1.5px solid var(--line); display: inline-flex; align-items: center; justify-content: center; transition: border-color .15s; }
.pvol-radio::after { content: ""; width: 8px; height: 8px; border-radius: 50%; background: var(--gold); opacity: 0; transition: opacity .15s; }
.pvol-tier.is-active { border-color: var(--gold); background: color-mix(in srgb, #fff 90%, var(--gold) 10%); }
.pvol-tier.is-active .pvol-radio { border-color: var(--gold); }
.pvol-tier.is-active .pvol-radio::after { opacity: 1; }
.pvol-tier:hover { border-color: var(--gold); }
.pvol-body { flex: 1; display: flex; flex-direction: column; gap: .25rem; min-width: 0; }
.pvol-row { display: flex; align-items: center; gap: .5rem; flex-wrap: wrap; }
.pvol-title { font-size: 12px; letter-spacing: .12em; text-transform: uppercase; font-weight: 700; color: var(--ink); }
.pvol-badge { background: var(--gold); color: var(--ink); font-size: 10px; letter-spacing: .12em; text-transform: uppercase; font-weight: 700; padding: 2px 8px; border-radius: 999px; }
.pvol-sub { font-size: 13px; color: var(--mid); line-height: 1.5; }
.pvol-sub strong { color: var(--ink); font-weight: 700; }
.pvol-fine { font-size: 12px; color: var(--mid); text-align: center; margin: .75rem 0 0; letter-spacing: .02em; }
.product-atc-sub { font-size: 12px; color: var(--mid); text-align: center; margin: .5rem 0 0; line-height: 1.5; }
.product-atc-sub strong { color: var(--ink); font-weight: 700; }

/* Trust badges row */
.product-trust { list-style: none; padding: 1rem 0 0; margin: 0; display: grid; grid-template-columns: repeat(2, 1fr); gap: .75rem 1rem; }
@media (min-width: 640px) { .product-trust { grid-template-columns: repeat(4, 1fr); } }
.product-trust li { display: flex; align-items: center; gap: .6rem; }
.product-trust-icon { flex-shrink: 0; width: 36px; height: 36px; border-radius: 50%; background: rgba(200,16,46,.08); display: inline-flex; align-items: center; justify-content: center; color: var(--red); }
.product-trust-icon svg { width: 18px; height: 18px; }
.product-trust-copy { display: flex; flex-direction: column; min-width: 0; }
.product-trust-copy strong { font-size: 12px; font-weight: 600; line-height: 1.25; color: var(--ink); }
.product-trust-copy small { font-size: 11px; line-height: 1.35; color: var(--mid); }
.product-tabs { margin-top: 3rem; }
.product-tabs-nav { display: flex; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); overflow-x: auto; }
.product-tab { padding: 0 1.25rem; height: 56px; font-size: 13px; letter-spacing: .12em; text-transform: uppercase; font-weight: 500; color: var(--mid); border-bottom: 2px solid transparent; white-space: nowrap; }
@media (min-width: 768px) { .product-tab { padding: 0 1.75rem; } }
.product-tab.is-active { color: var(--ink); border-bottom-color: var(--red); }
.product-tab-body { padding: 2.5rem 0; max-width: 48rem; }
.product-panel { display: none; }
.product-panel.is-active { display: block; }
.product-panel p { color: var(--mid); line-height: 1.7; }
.product-panel p + p { margin-top: 1rem; }
.product-benefit-list { margin-top: 1.5rem; display: flex; flex-direction: column; gap: .75rem; }
.product-benefit-list li { display: flex; gap: .75rem; color: var(--ink); }
.product-benefit-list svg { color: var(--red); flex-shrink: 0; margin-top: 2px; }
.product-howto { display: flex; flex-direction: column; gap: 1.25rem; }
.product-howto li { display: flex; gap: 1rem; line-height: 1.7; }
.product-howto-n { width: 40px; height: 40px; border-radius: 50%; background: var(--red); color: #fff; display: inline-flex; align-items: center; justify-content: center; font-family: var(--display); flex-shrink: 0; }
.product-box { display: flex; flex-direction: column; gap: .75rem; }
.product-box li { display: flex; align-items: center; gap: .75rem; }
.product-box-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--red); }
.product-specs { border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
.product-specs > div { display: grid; grid-template-columns: 180px 1fr; gap: 1rem; padding: 1rem 0; border-top: 1px solid var(--line); }
.product-specs > div:first-child { border-top: 0; }
.product-specs dt { font-size: 11px; letter-spacing: .15em; text-transform: uppercase; color: var(--mid); }
/* Mobile PDP: cap hero image to ~65vh so price + variant selector clear
   the fold on iPhone-class viewports. Drops the forced 1:1 aspect so
   height can actually take effect. Tightens section/grid padding on the
   same breakpoint to reclaim ~40px more for the buy-box. */
@media (max-width: 767px) {
  .product-section { padding-top: .75rem; }
  .product-grid { padding: 1rem 0; gap: 1.5rem; }
  .product-main-img img {
    aspect-ratio: auto;
    width: 100%;
    height: 65vh;
    max-height: 560px;
    min-height: 340px;
    object-fit: cover;
    object-position: center;
  }
}
{%- endstylesheet -%}

<script>
(function () {
  var container = document.querySelector('[data-pvol]');
  if (!container) return;
  var form = document.querySelector('[data-product-form]');
  var qtyInput = form && form.querySelector('input[name=quantity]');
  var total = document.querySelector('[data-atc-total]');
  var sub = document.querySelector('[data-atc-sub]');
  var subTotal = document.querySelector('[data-atc-sub-total]');

  var unitPence = parseInt((form && form.getAttribute('data-unit-pence')) || '0', 10);
  var tier2Pct = parseInt(container.getAttribute('data-tier2-pct') || '15', 10);
  var tier3Pct = parseInt(container.getAttribute('data-tier3-pct') || '23', 10);

  // Pull initial money symbol from the server-rendered ATC total so we match locale.
  var initialText = (total && total.textContent) || '£0.00';
  var symMatch = initialText.match(/^[^\d\-]*/);
  var symbol = (symMatch && symMatch[0]) || '£';

  function fmt(pence) {
    var amt = (pence / 100).toFixed(2);
    return symbol + amt;
  }

  function apply(qty) {
    qty = qty || 1;
    var discountPct = 0;
    if (qty === 2) discountPct = tier2Pct;
    else if (qty >= 3) discountPct = tier3Pct;

    var preTotal = unitPence * qty;
    var afterTotal = Math.round(preTotal * (100 - discountPct) / 100);

    // ATC button — honest pre-discount total (what Shopify charges before auto-discount).
    if (total) total.textContent = fmt(preTotal);

    // Muted sub line — only show when a volume discount applies.
    if (sub && subTotal) {
      if (discountPct > 0) {
        subTotal.textContent = fmt(afterTotal);
        sub.hidden = false;
      } else {
        sub.hidden = true;
      }
    }
  }

  container.addEventListener('click', function (e) {
    var tier = e.target.closest('.pvol-tier');
    if (!tier) return;
    container.querySelectorAll('.pvol-tier').forEach(function (t) { t.classList.remove('is-active'); });
    tier.classList.add('is-active');
    var qty = parseInt(tier.getAttribute('data-pvol-qty'), 10) || 1;
    if (qtyInput) qtyInput.value = qty;
    var radio = tier.querySelector('input[type=radio]');
    if (radio) radio.checked = true;
    apply(qty);
  });

  // Initial sync — the server rendered tier 2 as is-active, so reflect that in the ATC button and sub line.
  var initialActive = container.querySelector('.pvol-tier.is-active');
  var initialQty = initialActive ? (parseInt(initialActive.getAttribute('data-pvol-qty'), 10) || 1) : 1;
  apply(initialQty);
})();
</script>

