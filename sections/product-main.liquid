      "type": "header",
      "content": "Volume discount tiers"
    },
    {
      "type": "paragraph",
      "content": "Set the advertised savings shown on the pack selector. These must match the automatic discounts you configure in Shopify admin → Discounts (e.g. '15% off when buying 2+ of this product')."
    },
    {
      "type": "range",
      "id": "tier2_discount_pct",
      "label": "2-pack discount (%)",
      "min": 0,
      "max": 50,
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "tier3_discount_pct",
      "label": "3-pack discount (%)",
      "min": 0,
      "max": 50,
      "step": 1,
      "default": 23
    }
  ]
}
