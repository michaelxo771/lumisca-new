<section class="sci-articles">
  <div class="container">
    <div class="sci-articles-head">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="display-lg">{{ section.settings.heading }}</h2>
    </div>

    <div class="sci-articles-grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.url | default: '#' }}" class="sci-article" {{ block.shopify_attributes }}>
          <div class="sci-article-media">
            {%- if block.settings.image_filename != blank -%}
              <img src="{{ block.settings.image_filename | asset_url }}" alt="{{ block.settings.title | escape }}" loading="lazy">
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="sci-article-body">
            <p class="sci-article-category">{{ block.settings.category }}</p>
            <h3 class="sci-article-title">{{ block.settings.title }}</h3>
            <p class="sci-article-summary muted">{{ block.settings.summary }}</p>
            <span class="sci-article-more">Read more →</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- stylesheet -%}
.sci-articles { background: var(--cream); padding: 80px 0; }
@media (max-width: 768px) { .sci-articles { padding: 56px 0; } }
.sci-articles-head { margin-bottom: 2.5rem; }
.sci-articles-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
@media (min-width: 640px) { .sci-articles-grid { grid-template-columns: 1fr 1fr; } }
@media (min-width: 1024px) { .sci-articles-grid { grid-template-columns: repeat(4, 1fr); gap: 1.25rem; } }
.sci-article { display: flex; flex-direction: column; background: #fff; border: 1px solid var(--line); color: inherit; transition: transform .3s ease, box-shadow .3s ease; border-radius: 10px; overflow: hidden; }
.sci-article:hover { transform: translateY(-4px); box-shadow: 0 20px 60px -20px rgba(10,10,10,.18); }
.sci-article-media { aspect-ratio: 4/3; background: #efece8; overflow: hidden; }
.sci-article-media img, .sci-article-media svg { width: 100%; height: 100%; object-fit: cover; display: block; }
.sci-article-body { padding: 1.25rem; display: flex; flex-direction: column; gap: .5rem; flex: 1; }
.sci-article-category { font-size: 11px; letter-spacing: .18em; text-transform: uppercase; color: var(--red); font-weight: 600; margin: 0; }
.sci-article-title { font-family: var(--display); font-size: 1.125rem; line-height: 1.25; margin: 0; }
.sci-article-summary { font-size: 13px; line-height: 1.55; margin: 0; flex: 1; }
.sci-article-more { font-size: 13px; font-weight: 600; color: var(--ink); border-bottom: 1px solid var(--ink); padding-bottom: 2px; align-self: flex-start; margin-top: .5rem; }
.sci-article:hover .sci-article-more { color: var(--red); border-bottom-color: var(--red); }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Science Articles Grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "ARTICLES" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Read deeper." }
  ],
  "blocks": [
    {
      "type": "article",
      "name": "Article",
      "settings": [
        { "type": "text", "id": "image_filename", "label": "Image asset filename" },
        { "type": "text", "id": "category", "label": "Category", "default": "Wavelengths" },
        { "type": "text", "id": "title", "label": "Title", "default": "Why 660nm and 850nm outperform other light therapies" },
        { "type": "text", "id": "summary", "label": "Summary", "default": "The physics of tissue penetration — and why most at-home devices get it wrong." },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Science Articles Grid",
      "blocks": [
        { "type": "article", "settings": { "image_filename": "product-cap-solo.png",      "category": "Wavelengths",       "title": "Why 660nm and 850nm outperform other light therapies", "summary": "The physics of tissue penetration — and why most at-home devices get it wrong.", "url": "/pages/science-wavelengths" } },
        { "type": "article", "settings": { "image_filename": "hero-hair-cap-dramatic.png","category": "Hair Loss",         "title": "The 2018 Harvard study that changed everything",       "summary": "A landmark trial that moved LLLT from fringe to first-line therapy.",           "url": "/pages/science-hair-loss" } },
        { "type": "article", "settings": { "image_filename": "product-mask-solo.png",     "category": "Skin",              "title": "How red light triggers collagen production",           "summary": "Inside the fibroblast pathway that drives every visible improvement.",           "url": "/pages/science-skin" } },
        { "type": "article", "settings": { "image_filename": "lifestyle-face-mask.png",   "category": "Clinical Trials",   "title": "3,000+ peer-reviewed studies: what they found",        "summary": "A survey of the evidence base — effect sizes, dosing, and open questions.",     "url": "/pages/science-studies" } }
      ]
    }
  ]
}
{% endschema %}
