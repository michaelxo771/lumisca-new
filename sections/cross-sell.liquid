{%- liquid
  assign handle = product.handle | default: ''
  assign cat = 'hair'
  if handle contains 'face' or handle contains 'glow' or handle contains 'mask'
    assign cat = 'face'
  endif
  if handle contains 'eye' or handle contains 'rest'
    assign cat = 'eye'
  endif
  if handle contains 'bundle' or handle contains 'complete'
    assign cat = 'bundle'
  endif
-%}

<section class="xsell">
  <div class="container">
    <div class="xsell-head">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="display-md">{{ section.settings.heading }}</h2>
    </div>

    <div class="xsell-grid">
      {%- comment -%} All 4 candidates; we skip the current product's card by cat match. {%- endcomment -%}

      {%- unless cat == 'hair' -%}
        <a href="/products/pro-red-light-hair-growth-cap" class="xsell-card">
          <div class="xsell-media"><img src="{{ 'product-cap-solo.png' | asset_url }}" alt="Pro Red Light Hair Growth Cap" loading="lazy"></div>
          <div class="xsell-body">
            <h3 class="xsell-name">Pro Red Light Hair Growth Cap</h3>
            <p class="xsell-hook muted">Clinic-grade hair regrowth, built into a cap</p>
            <div class="xsell-price">
              <span class="xsell-now">£64.99</span>
              <span class="xsell-was">£129.99</span>
            </div>
            <span class="xsell-cta">Add to routine →</span>
          </div>
        </a>
      {%- endunless -%}

      {%- unless cat == 'face' -%}
        <a href="/products/glow-red-light-face-mask" class="xsell-card">
          <div class="xsell-media"><img src="{{ 'product-mask-solo.png' | asset_url }}" alt="Glow Red Light Face Mask" loading="lazy"></div>
          <div class="xsell-body">
            <h3 class="xsell-name">Glow Red Light Face Mask</h3>
            <p class="xsell-hook muted">Salon-grade skincare, 10 minutes a day</p>
            <div class="xsell-price">
              <span class="xsell-now">£54.99</span>
              <span class="xsell-was">£109.99</span>
            </div>
            <span class="xsell-cta">Add to routine →</span>
          </div>
        </a>
      {%- endunless -%}

      {%- unless cat == 'eye' -%}
        <a href="/products/rest-heated-eye-mask" class="xsell-card">
          <div class="xsell-media"><img src="{{ 'product-eye-mask-solo.png' | asset_url }}" alt="Rest Heated Eye Mask" loading="lazy"></div>
          <div class="xsell-body">
            <h3 class="xsell-name">Rest Heated Eye Mask</h3>
            <p class="xsell-hook muted">Deeper sleep in 10 minutes</p>
            <div class="xsell-price">
              <span class="xsell-now">£29.99</span>
              <span class="xsell-was">£59.99</span>
            </div>
            <span class="xsell-cta">Add to routine →</span>
          </div>
        </a>
      {%- endunless -%}

      {%- unless cat == 'bundle' -%}
        <a href="/products/lumisca-complete-bundle" class="xsell-card xsell-card-featured">
          <div class="xsell-media"><img src="{{ 'product-duo-side.png' | asset_url }}" alt="Complete Lumisca Bundle" loading="lazy"></div>
          <div class="xsell-body">
            <h3 class="xsell-name">The Complete Lumisca Bundle</h3>
            <p class="xsell-hook muted">All three devices — save £174.98</p>
            <div class="xsell-price">
              <span class="xsell-now">£124.99</span>
              <span class="xsell-was">£299.97</span>
            </div>
            <span class="xsell-cta">Add to routine →</span>
          </div>
        </a>
      {%- endunless -%}
    </div>
  </div>
</section>

{%- stylesheet -%}
.xsell { background: var(--cream); padding: 80px 0; }
@media (max-width: 768px) { .xsell { padding: 56px 0; } }
.xsell-head { text-align: center; max-width: 640px; margin: 0 auto 2.5rem; }
.xsell-grid { display: grid; grid-template-columns: 1fr; gap: 1.25rem; max-width: 1100px; margin: 0 auto; }
@media (min-width: 640px) { .xsell-grid { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 900px) { .xsell-grid { grid-template-columns: repeat(3, 1fr); gap: 1.5rem; } }

.xsell-card { display: flex; flex-direction: column; background: #fff; border: 1px solid var(--line); border-radius: 12px; overflow: hidden; color: inherit; text-decoration: none; transition: transform .2s, box-shadow .2s, border-color .2s; }
.xsell-card:hover { transform: translateY(-4px); box-shadow: 0 20px 60px -22px rgba(10,10,10,.15); border-color: var(--red); }
.xsell-card-featured { border: 2px solid var(--gold); }
.xsell-card-featured:hover { border-color: var(--gold); box-shadow: 0 20px 60px -22px rgba(201,168,76,.3); }

.xsell-media { aspect-ratio: 4/3; background: #fafafa; overflow: hidden; }
.xsell-media img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .5s; }
.xsell-card:hover .xsell-media img { transform: scale(1.04); }
.xsell-body { padding: 1.25rem; display: flex; flex-direction: column; gap: .35rem; }
.xsell-name { font-family: var(--display); font-size: 1.125rem; line-height: 1.25; margin: 0; color: var(--ink); }
.xsell-hook { font-size: 13px; line-height: 1.5; margin: 0; }
.xsell-price { display: flex; align-items: baseline; gap: .5rem; margin-top: .4rem; }
.xsell-now { font-family: var(--display); font-size: 1.35rem; font-weight: 700; color: var(--red); }
.xsell-was { font-size: 12px; color: var(--mid); text-decoration: line-through; }
.xsell-cta { margin-top: .75rem; font-size: 12px; letter-spacing: .1em; text-transform: uppercase; font-weight: 600; color: var(--ink); border-bottom: 1px solid var(--ink); padding-bottom: 2px; align-self: flex-start; transition: color .15s, border-color .15s; }
.xsell-card:hover .xsell-cta { color: var(--red); border-bottom-color: var(--red); }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Cross Sell",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "COMPLETE THE RITUAL" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Pairs well with" }
  ],
  "presets": [ { "name": "Cross Sell" } ]
}
{% endschema %}
