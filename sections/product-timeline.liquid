{%- liquid
  assign handle = product.handle | default: ''
  assign cat = 'hair'
  if handle contains 'face' or handle contains 'glow' or handle contains 'mask'
    assign cat = 'face'
  endif
  if handle contains 'eye' or handle contains 'rest'
    assign cat = 'eye'
  endif
  if handle contains 'bundle' or handle contains 'complete'
    assign cat = 'bundle'
  endif
-%}

<section class="ptl">
  <div class="container">
    <div class="ptl-head">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="display-md">{{ section.settings.heading }}</h2>
    </div>

    <ol class="ptl-track">
      {%- case cat -%}
        {%- when 'face' -%}
          <li class="ptl-step"><span class="ptl-dot"></span><p class="ptl-when">Day 1–7</p><h3 class="ptl-title">Radiance shift</h3><p class="ptl-body">Skin looks more hydrated and even. Post-treatment glow.</p></li>
          <li class="ptl-step ptl-step-peak"><span class="ptl-dot"></span><p class="ptl-when">Week 2–4</p><h3 class="ptl-title">Texture improvement</h3><p class="ptl-body">Roughness and uneven patches smooth. Breakouts calm.</p></li>
          <li class="ptl-step ptl-step-peak"><span class="ptl-dot"></span><p class="ptl-when">Week 4–8</p><h3 class="ptl-title">Fine-line reduction</h3><p class="ptl-body">Smile lines and crow's feet soften. Skin firms.</p></li>
          <li class="ptl-step"><span class="ptl-dot"></span><p class="ptl-when">Month 3+</p><h3 class="ptl-title">Lasting change</h3><p class="ptl-body">Collagen production is compounded. Your skin age visibly reverses.</p></li>
        {%- when 'eye' -%}
          <li class="ptl-step"><span class="ptl-dot"></span><p class="ptl-when">Night 1–3</p><h3 class="ptl-title">Immediate calm</h3><p class="ptl-body">Heat eases eye strain. Faster sleep onset.</p></li>
          <li class="ptl-step ptl-step-peak"><span class="ptl-dot"></span><p class="ptl-when">Week 1–2</p><h3 class="ptl-title">Deeper sleep</h3><p class="ptl-body">REM cycles extend. Morning grogginess fades.</p></li>
          <li class="ptl-step ptl-step-peak"><span class="ptl-dot"></span><p class="ptl-when">Week 3–4</p><h3 class="ptl-title">Less tension</h3><p class="ptl-body">Migraine frequency drops. Dry eyes improve.</p></li>
          <li class="ptl-step"><span class="ptl-dot"></span><p class="ptl-when">Ongoing</p><h3 class="ptl-title">A better nightly ritual</h3><p class="ptl-body">Your nervous system learns to downshift on cue.</p></li>
        {%- when 'bundle' -%}
          <li class="ptl-step"><span class="ptl-dot"></span><p class="ptl-when">Week 1</p><h3 class="ptl-title">Sleep shifts first</h3><p class="ptl-body">Rest mask calms the nervous system from night one.</p></li>
          <li class="ptl-step ptl-step-peak"><span class="ptl-dot"></span><p class="ptl-when">Week 4</p><h3 class="ptl-title">Skin glows up</h3><p class="ptl-body">Glow mask kicks in. Radiance, even tone, firmer texture.</p></li>
          <li class="ptl-step ptl-step-peak"><span class="ptl-dot"></span><p class="ptl-when">Week 8–12</p><h3 class="ptl-title">Hair density</h3><p class="ptl-body">Cap results arrive last and compound the longest.</p></li>
          <li class="ptl-step"><span class="ptl-dot"></span><p class="ptl-when">Month 6+</p><h3 class="ptl-title">Full transformation</h3><p class="ptl-body">All three routines compounded into one daily habit.</p></li>
        {%- else -%}
          {%- comment -%}
            Phase 3 — three pre-rendered hair timeline variants gated by
            .aud-only-* on the wrapping <ol> ancestor. Liquid can't gate a
            <li> sequence cleanly, so each variant gets its own four-step
            block. CSS hides the non-matching variant.
          {%- endcomment -%}
          <span class="aud-only-generic" style="display:contents;">
            <li class="ptl-step"><span class="ptl-dot"></span><p class="ptl-when">Week 1–2</p><h3 class="ptl-title">First sessions</h3><p class="ptl-body">Scalp feels warmed and circulation increases. Some users report reduced scalp tension.</p></li>
            <li class="ptl-step ptl-step-peak"><span class="ptl-dot"></span><p class="ptl-when">Week 4–6</p><h3 class="ptl-title">Reduced shedding</h3><p class="ptl-body">You'll notice less hair in the shower drain and on your pillow.</p></li>
            <li class="ptl-step ptl-step-peak"><span class="ptl-dot"></span><p class="ptl-when">Week 8–12</p><h3 class="ptl-title">Visible density</h3><p class="ptl-body">Fine baby hairs emerging at hairline and crown. Existing hair looks thicker.</p></li>
            <li class="ptl-step"><span class="ptl-dot"></span><p class="ptl-when">Month 6+</p><h3 class="ptl-title">Transformation</h3><p class="ptl-body">Complete cycle of new growth. Photos side-by-side show the difference.</p></li>
          </span>
          <span class="aud-only-women" style="display:contents;">
            <li class="ptl-step"><span class="ptl-dot"></span><p class="ptl-when">Week 1–2</p><h3 class="ptl-title">First sessions</h3><p class="ptl-body">Scalp feels warmed and circulation increases. Many women report reduced scalp tension and tightness.</p></li>
            <li class="ptl-step ptl-step-peak"><span class="ptl-dot"></span><p class="ptl-when">Week 4–6</p><h3 class="ptl-title">Reduced shedding</h3><p class="ptl-body">You'll notice less hair on your pillow, in the shower drain, and on your hairbrush.</p></li>
            <li class="ptl-step ptl-step-peak"><span class="ptl-dot"></span><p class="ptl-when">Week 8–12</p><h3 class="ptl-title">Visible density</h3><p class="ptl-body">Fine baby hairs emerging at the parting, hairline, and crown. Existing hair feels thicker.</p></li>
            <li class="ptl-step"><span class="ptl-dot"></span><p class="ptl-when">Month 6+</p><h3 class="ptl-title">Transformation</h3><p class="ptl-body">Your hairdresser will notice. Parting looks fuller, hairline more defined.</p></li>
          </span>
          <span class="aud-only-men" style="display:contents;">
            <li class="ptl-step"><span class="ptl-dot"></span><p class="ptl-when">Week 1–2</p><h3 class="ptl-title">First sessions</h3><p class="ptl-body">Scalp feels warmed and circulation increases. Some men report reduced scalp tightness.</p></li>
            <li class="ptl-step ptl-step-peak"><span class="ptl-dot"></span><p class="ptl-when">Week 4–6</p><h3 class="ptl-title">Reduced shedding</h3><p class="ptl-body">Fewer hairs on the pillow and in the sink. Loss patterns slow.</p></li>
            <li class="ptl-step ptl-step-peak"><span class="ptl-dot"></span><p class="ptl-when">Week 8–12</p><h3 class="ptl-title">Visible regrowth</h3><p class="ptl-body">Fine new hairs emerging at the hairline and crown. Existing hair appears denser.</p></li>
            <li class="ptl-step"><span class="ptl-dot"></span><p class="ptl-when">Month 6+</p><h3 class="ptl-title">Transformation</h3><p class="ptl-body">Hairline pulled forward, crown filled in. Photos look noticeably different.</p></li>
          </span>
      {%- endcase -%}
    </ol>
  </div>
</section>

{%- stylesheet -%}
.ptl { background: var(--cream); padding: 80px 0; }
@media (max-width: 768px) { .ptl { padding: 56px 0; } }
.ptl-head { text-align: center; max-width: 680px; margin: 0 auto 3rem; }
.ptl-track { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr; gap: 1.5rem; position: relative; }
@media (min-width: 900px) { .ptl-track { grid-template-columns: repeat(4, 1fr); gap: 1.25rem; padding-top: 48px; } }

.ptl-track::before {
  content: "";
  position: absolute;
  background: var(--gold);
  left: 16px; top: 24px; bottom: 24px; width: 2px;
}
@media (min-width: 900px) {
  .ptl-track::before {
    left: 7%; right: 7%; top: 24px; bottom: auto; width: auto; height: 2px;
  }
}

.ptl-step { position: relative; padding-left: 48px; }
@media (min-width: 900px) { .ptl-step { padding-left: 0; padding-top: 48px; text-align: center; } }

.ptl-dot { position: absolute; left: 8px; top: 8px; width: 18px; height: 18px; border-radius: 50%; background: var(--gold); border: 4px solid var(--cream); box-sizing: content-box; z-index: 1; }
.ptl-step-peak .ptl-dot { background: var(--red); width: 22px; height: 22px; left: 6px; top: 6px; }
@media (min-width: 900px) {
  .ptl-dot { left: 50%; top: 12px; transform: translateX(-50%); }
  .ptl-step-peak .ptl-dot { left: 50%; top: 10px; transform: translateX(-50%); }
}

.ptl-when { font-size: 11px; letter-spacing: .22em; text-transform: uppercase; color: var(--red); font-weight: 700; margin: 0 0 .5rem; }
.ptl-title { font-family: var(--display); font-size: 1.25rem; line-height: 1.25; margin: 0 0 .5rem; }
.ptl-body { color: var(--mid); font-size: 14px; line-height: 1.6; margin: 0; max-width: 220px; }
@media (min-width: 900px) { .ptl-body { margin: 0 auto; } }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Results Timeline",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "YOUR TIMELINE" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What to expect, when." }
  ],
  "presets": [ { "name": "Results Timeline" } ]
}
{% endschema %}
