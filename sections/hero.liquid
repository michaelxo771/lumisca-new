<section class="hero section-dark">
  <div class="hero-glow"></div>
  <div class="container hero-inner">
    <div class="hero-copy">
      {%- if section.settings.show_badge -%}
        <span class="hero-badge">
          <span class="hero-badge-dot"></span>
          {{ section.settings.badge_text }}
        </span>
      {%- endif -%}

      <h1 class="display-xl hero-title">{{ section.settings.heading }}</h1>
      <p class="hero-sub muted">{{ section.settings.subheading }}</p>

      <div class="hero-ctas">
        {%- if section.settings.cta1_label != blank -%}
          <a href="{{ section.settings.cta1_url | default: '/collections/all' }}" class="btn btn-red btn-xl">
            {{ section.settings.cta1_label }} {% render 'icon-arrow-right' %}
          </a>
        {%- endif -%}
        {%- if section.settings.cta2_label != blank -%}
          <a href="{{ section.settings.cta2_url | default: '/pages/science' }}" class="btn btn-outline-light btn-xl">
            {{ section.settings.cta2_label }}
          </a>
        {%- endif -%}
      </div>

      <ul class="hero-stats">
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat' -%}
            <li {{ block.shopify_attributes }}>
              <span class="hero-stat-n">{{ block.settings.value }}</span>
              <span class="hero-stat-l">{{ block.settings.label }}</span>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

    <div class="hero-media">
      <div class="hero-media-frame">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 1000 }}" alt="{{ section.settings.image.alt | escape }}" loading="eager" width="1000" height="1250">
        {%- else -%}
          <div class="hero-placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
        <span class="hero-tag hero-tag-red">Clinic-Grade</span>
        <span class="hero-tag hero-tag-gold">Best of 2026</span>
      </div>
    </div>
  </div>
</section>

{%- stylesheet -%}
.hero { overflow: hidden; }
.hero-inner { position: relative; padding: 3.5rem 1rem; display: grid; grid-template-columns: 1fr; gap: 2.5rem; align-items: center; min-height: calc(100vh - 6.5rem); }
@media (min-width: 1024px) { .hero-inner { grid-template-columns: 1fr 1fr; gap: 3.5rem; padding: 5rem 1rem; } }
.hero-badge { display: inline-flex; align-items: center; gap: .5rem; padding: .5rem 1rem; background: rgba(200,16,46,.1); border: 1px solid rgba(200,16,46,.4); font-size: 11px; letter-spacing: .2em; text-transform: uppercase; font-weight: 500; width: fit-content; }
.hero-badge-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--red); animation: pulse 2.8s ease-in-out infinite; }
@keyframes pulse { 0%,100% { opacity: .85 } 50% { opacity: 1 } }
.hero-title { margin-top: 1.5rem; }
.hero-title em, .hero-title .red { font-style: normal; color: var(--red); }
.hero-sub { margin-top: 1.5rem; max-width: 34rem; font-size: 1.125rem; line-height: 1.65; }
.hero-ctas { margin-top: 2rem; display: flex; flex-direction: column; gap: .75rem; }
@media (min-width: 640px) { .hero-ctas { flex-direction: row; } }
.hero-stats { margin-top: 3rem; display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; max-width: 28rem; }
.hero-stat-n { font-family: var(--display); font-size: 1.5rem; display: block; }
@media (min-width: 768px) { .hero-stat-n { font-size: 1.875rem; } }
.hero-stat-l { font-size: 11px; letter-spacing: .18em; text-transform: uppercase; color: rgba(249,247,244,.6); margin-top: .25rem; display: block; }
.hero-media-frame { position: relative; border: 2px dashed rgba(200,16,46,.5); }
.hero-media-frame img, .hero-placeholder { width: 100%; aspect-ratio: 4/5; object-fit: cover; display: block; }
.hero-placeholder { background: #141414; display: flex; align-items: center; justify-content: center; }
.hero-placeholder svg { width: 100%; height: 100%; fill: rgba(255,255,255,.15); }
.hero-tag { position: absolute; font-size: 11px; letter-spacing: .2em; text-transform: uppercase; font-weight: 500; padding: .5rem 1rem; }
.hero-tag-red { bottom: -1.25rem; left: -1.25rem; background: var(--red); color: #fff; }
.hero-tag-gold { top: -1rem; right: 1rem; background: var(--gold); color: var(--ink); font-weight: 600; }
@media (min-width: 768px) { .hero-tag-gold { right: -1.5rem; } }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show TikTok badge",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "As Seen On TikTok"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your At-Home Light Therapy Clinic."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Clinic-grade red light therapy for hair, skin and sleep — delivered to your door, designed for your sofa. Over 10,000 UK customers. 60-day money back guarantee."
    },
    {
      "type": "text",
      "id": "cta1_label",
      "label": "CTA 1 label",
      "default": "Shop The Collection"
    },
    {
      "type": "url",
      "id": "cta1_url",
      "label": "CTA 1 link"
    },
    {
      "type": "text",
      "id": "cta2_label",
      "label": "CTA 2 label",
      "default": "See The Science"
    },
    {
      "type": "url",
      "id": "cta2_url",
      "label": "CTA 2 link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "10,000+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Customers"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "value": "10,000+",
            "label": "Customers"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "4.9 ★",
            "label": "Rated"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "60-Day",
            "label": "Money Back"
          }
        }
      ]
    }
  ]
}
{% endschema %}
