<section class="hero-v2">
  <div class="hero-v2-media">
    <video
      class="hero-v2-video"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="{{ 'hero-hair-cap-dramatic.png' | asset_url }}"
    >
      <source src="{{ 'hero-video.mp4' | asset_url }}" type="video/mp4">
    </video>
    <img
      class="hero-v2-mobile-img"
      src="{{ 'hero-hair-cap-dramatic.png' | asset_url }}"
      alt="{{ section.settings.heading | escape }}"
    >
    <div class="hero-v2-overlay"></div>
  </div>

  <div class="hero-v2-content">
    <div class="hero-v2-inner">
      {%- if section.settings.show_badge -%}
        <span class="hero-v2-pill">
          <span class="hero-v2-dot"></span>
          {{ section.settings.badge_text }}
        </span>
      {%- endif -%}

      <h1 class="hero-v2-title">{{ section.settings.heading }}</h1>

      {%- if section.settings.subheading != blank -%}
        <p class="hero-v2-sub">{{ section.settings.subheading }}</p>
      {%- endif -%}

      <div class="hero-v2-ctas">
        {%- if section.settings.cta1_label != blank -%}
          <a href="{{ section.settings.cta1_url | default: '/collections/all' }}" class="btn btn-red btn-xl">
            {{ section.settings.cta1_label }} {% render 'icon-arrow-right' %}
          </a>
        {%- endif -%}
        {%- if section.settings.cta2_label != blank -%}
          <a href="{{ section.settings.cta2_url | default: '/pages/science' }}" class="btn btn-outline-light btn-xl">
            {{ section.settings.cta2_label }}
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.quiz_label != blank -%}
        <a href="{{ section.settings.quiz_url | default: '/pages/quiz' }}" class="hero-v2-quiz-link">
          {{ section.settings.quiz_label }}
        </a>
      {%- endif -%}

      <ul class="hero-v2-stats">
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat' -%}
            <li {{ block.shopify_attributes }}>
              <span class="hero-v2-stat-n">{{ block.settings.value }}</span>
              <span class="hero-v2-stat-l">{{ block.settings.label }}</span>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>
  </div>
</section>

{%- stylesheet -%}
.hero-v2 { position: relative; width: 100%; min-height: 70vh; color: #fff; overflow: hidden; background: #0a0a0a; }
@media (min-width: 768px) { .hero-v2 { min-height: 90vh; } }
.hero-v2-media { position: absolute; inset: 0; }
.hero-v2-video, .hero-v2-mobile-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
.hero-v2-video { display: none; }
.hero-v2-mobile-img { display: block; }
@media (min-width: 768px) { .hero-v2-video { display: block; } .hero-v2-mobile-img { display: none; } }
.hero-v2-overlay { position: absolute; inset: 0; background: rgba(0,0,0,.55); }
.hero-v2-content { position: relative; z-index: 2; display: flex; align-items: center; min-height: inherit; padding: 4rem 1.25rem; }
@media (min-width: 768px) { .hero-v2-content { padding: 5rem 2rem; } }
.hero-v2-inner { max-width: 640px; width: 100%; }
.hero-v2-pill { display: inline-flex; align-items: center; gap: .5rem; padding: .4rem 1rem; background: rgba(200,16,46,.95); color: #fff; font-size: 11px; letter-spacing: .2em; text-transform: uppercase; font-weight: 600; border-radius: 999px; }
.hero-v2-dot { width: 6px; height: 6px; border-radius: 50%; background: #fff; }
.hero-v2-title { margin: 1.5rem 0; font-family: var(--display); font-size: clamp(2.75rem, 6vw, 5rem); line-height: 1.05; letter-spacing: -0.02em; font-weight: 600; }
.hero-v2-sub { margin-bottom: 2rem; max-width: 36rem; font-size: 1.05rem; line-height: 1.65; color: rgba(255,255,255,.82); }
.hero-v2-ctas { display: flex; flex-direction: column; gap: .75rem; margin-bottom: 3rem; }
@media (min-width: 640px) { .hero-v2-ctas { flex-direction: row; } }
.hero-v2-quiz-link { display: inline-block; margin: -1.5rem 0 2.5rem; font-size: 13px; color: rgba(255,255,255,.72); text-decoration: underline; text-underline-offset: 4px; transition: color .15s; }
.hero-v2-quiz-link:hover { color: var(--gold); }
.hero-v2-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; max-width: 34rem; border-top: 1px solid rgba(255,255,255,.18); padding-top: 1.5rem; }
.hero-v2-stat-n { font-family: var(--display); font-size: 1.5rem; display: block; }
@media (min-width: 768px) { .hero-v2-stat-n { font-size: 1.875rem; } }
.hero-v2-stat-l { font-size: 11px; letter-spacing: .15em; text-transform: uppercase; color: rgba(255,255,255,.65); margin-top: .25rem; display: block; }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "checkbox", "id": "show_badge", "label": "Show pill badge", "default": true },
    { "type": "text", "id": "badge_text", "label": "Pill text", "default": "● AS SEEN ON TIKTOK" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Your At-Home Light Therapy Clinic." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Clinical red light and near-infrared therapy for hair, skin and sleep — delivered to your door, designed for your sofa. Over 10,000 UK customers. 60-day money back guarantee." },
    { "type": "text", "id": "cta1_label", "label": "CTA 1 label", "default": "Shop The Collection" },
    { "type": "url", "id": "cta1_url", "label": "CTA 1 link" },
    { "type": "text", "id": "cta2_label", "label": "CTA 2 label", "default": "See The Science" },
    { "type": "url", "id": "cta2_url", "label": "CTA 2 link" },
    { "type": "text", "id": "quiz_label", "label": "Quiz link label", "default": "Not sure which is right for you? → Take the 60-second quiz" },
    { "type": "url", "id": "quiz_url", "label": "Quiz link URL" }
  ],
  "blocks": [
    { "type": "stat", "name": "Stat", "settings": [
      { "type": "text", "id": "value", "label": "Value", "default": "10,000+" },
      { "type": "text", "id": "label", "label": "Label", "default": "Customers" }
    ] }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "stat", "settings": { "value": "10,000+", "label": "Customers" } },
        { "type": "stat", "settings": { "value": "4.9 ★", "label": "Rated" } },
        { "type": "stat", "settings": { "value": "60-Day", "label": "Guarantee" } }
      ]
    }
  ]
}
{% endschema %}
