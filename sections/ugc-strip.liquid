<section class="section-lg section-dark ugc">
  <div class="container">
    <div class="ugc-head">
      <div>
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="display-lg">{{ section.settings.heading }}</h2>
      </div>
      <p class="muted ugc-lead">{{ section.settings.lead }}</p>
    </div>

    <div class="grid grid-md-3 grid-lg-5" style="gap:.75rem;">
      {%- for block in section.blocks -%}
        <div class="ugc-tile" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <a href="{{ block.settings.link }}" target="_blank" rel="noopener noreferrer">
              <img src="{{ block.settings.image | image_url: width: 500 }}" alt="{{ block.settings.caption | escape }}" loading="lazy" width="500" height="500">
            </a>
          {%- else -%}
            <div class="ph ph-dark aspect-square"><span class="ph-label">{{ block.settings.caption }}</span></div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- if settings.social_tiktok != blank -%}
      <div class="center" style="margin-top:2.5rem;">
        <a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener noreferrer" class="btn btn-outline-light btn-lg">
          {% render 'icon-tiktok' %} {{ section.settings.cta_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{%- stylesheet -%}
.ugc-head { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2.5rem; }
@media (min-width: 768px) { .ugc-head { flex-direction: row; align-items: flex-end; justify-content: space-between; } }
.ugc-lead { max-width: 22rem; line-height: 1.6; }
.ugc-lead strong, .ugc-tag { color: var(--gold); }
.ugc-tile img { width: 100%; aspect-ratio: 1/1; object-fit: cover; }
{%- endstylesheet -%}

{% schema %}
{
  "name": "UGC Strip",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Community"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join The Lumisca Community"
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Lead text",
      "default": "Tag @lumisca for a chance to feature — and see real Lumisca routines from real UK customers."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Follow @lumisca On TikTok"
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption",
          "default": "@lucyskin — 10 weeks of Glow"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "UGC Strip"
    }
  ]
}
{% endschema %}
