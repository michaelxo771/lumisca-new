<section class="unboxing">
  <div class="container unboxing-inner">
    <div class="unboxing-head">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="display-lg">{{ section.settings.heading }}</h2>
      {%- if section.settings.body != blank -%}
        <p class="muted unboxing-body">{{ section.settings.body }}</p>
      {%- endif -%}
    </div>

    <div class="unboxing-grid" data-fade-up>
      {%- for block in section.blocks -%}
        <figure class="unboxing-figure" {{ block.shopify_attributes }}>
          <img src="{{ block.settings.image_filename | asset_url }}" alt="{{ block.settings.alt | escape }}" loading="lazy">
        </figure>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- stylesheet -%}
.unboxing { background: var(--cream); padding: 120px 0; }
@media (max-width: 768px) { .unboxing { padding: 64px 0; } }
.unboxing-inner { text-align: center; }
.unboxing-head { max-width: 640px; margin: 0 auto 3.5rem; }
.unboxing-body { margin-top: 1rem; font-size: 1rem; line-height: 1.7; }
.unboxing-grid { display: grid; grid-template-columns: 1fr; gap: 20px; max-width: 1140px; margin: 0 auto; }
@media (min-width: 768px) { .unboxing-grid { grid-template-columns: 1fr 1fr; } }
.unboxing-figure { margin: 0; border-radius: 12px; overflow: hidden; background: #141414; aspect-ratio: 1/1; }
.unboxing-figure img { width: 100%; height: 100%; object-fit: cover; display: block; }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Unboxing Showcase",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "THE UNBOXING" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Arrives like a gift to yourself." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Every Lumisca device is packaged with the care of a luxury fragrance house — because you're buying a ritual, not just a device." }
  ],
  "blocks": [
    {
      "type": "shot",
      "name": "Shot",
      "settings": [
        { "type": "text", "id": "image_filename", "label": "Asset filename", "default": "unboxing-box-lift.png" },
        { "type": "text", "id": "alt", "label": "Alt text", "default": "LUMISCA unboxing" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Unboxing Showcase",
      "blocks": [
        { "type": "shot", "settings": { "image_filename": "unboxing-box-lift.png", "alt": "LUMISCA box being lifted from wrapping" } },
        { "type": "shot", "settings": { "image_filename": "unboxing-mask-open.png", "alt": "LUMISCA mask revealed inside the box" } }
      ]
    }
  ]
}
{% endschema %}
