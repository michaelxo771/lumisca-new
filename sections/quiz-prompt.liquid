<section class="qp">
  <div class="container qp-inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h2 class="display-lg qp-heading">{{ section.settings.heading }}</h2>
    {%- if section.settings.body != blank -%}
      <p class="qp-body muted">{{ section.settings.body }}</p>
    {%- endif -%}
    <a href="{{ section.settings.cta_url | default: '/pages/quiz' }}" class="btn btn-red btn-lg qp-cta">
      {{ section.settings.cta_label }} →
    </a>
    {%- if section.settings.cta_fine != blank -%}
      <p class="qp-fine">{{ section.settings.cta_fine }}</p>
    {%- endif -%}
  </div>
</section>

{%- stylesheet -%}
.qp { background: var(--cream); padding: 80px 0; }
@media (max-width: 768px) { .qp { padding: 56px 0; } }
.qp-inner { max-width: 640px; margin: 0 auto; text-align: center; }
.qp-heading { margin: 0 0 1rem; }
.qp-body { max-width: 560px; margin: 0 auto 1.75rem; line-height: 1.7; font-size: 1.0625rem; }
.qp-cta { border-radius: 6px; padding: 0 2rem; }
.qp-fine { margin-top: 1rem; font-size: 12px; letter-spacing: .04em; color: var(--mid); }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Quiz Prompt",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "FIND YOUR MATCH" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Take the 60-second Lumisca quiz." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Answer 7 quick questions and we'll recommend the right device for your concerns — plus 10% off your first order." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Start The Quiz" },
    { "type": "url", "id": "cta_url", "label": "CTA link" },
    { "type": "text", "id": "cta_fine", "label": "Fine print", "default": "Approx. 60 seconds · 10% off included" }
  ],
  "presets": [ { "name": "Quiz Prompt" } ]
}
{% endschema %}
