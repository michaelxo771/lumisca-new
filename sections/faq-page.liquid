<section class="section faq-page">
  <div class="container" style="max-width: 56rem;">
    <nav class="faq-nav" aria-label="FAQ sections">
      {%- for block in section.blocks -%}
        {%- if block.type == 'group' -%}
          <a href="#{{ block.settings.anchor }}" class="faq-nav-chip">{{ block.settings.title }}</a>
        {%- endif -%}
      {%- endfor -%}
    </nav>

    <div class="faq-groups">
      {%- for block in section.blocks -%}
        {%- if block.type == 'group' -%}
          <section id="{{ block.settings.anchor }}" class="faq-group" {{ block.shopify_attributes }}>
            <h2 class="display-md" style="margin-bottom:1rem;">{{ block.settings.title }}</h2>
            <div class="accordion">
              {%- assign questions = block.settings.questions | newline_to_br | split: '<br />' -%}
              {%- assign answers = block.settings.answers | newline_to_br | split: '<br />' -%}
              {%- for q in questions -%}
                {%- assign trimmed = q | strip -%}
                {%- if trimmed != '' -%}
                  <div class="accordion-item">
                    <button type="button" class="accordion-trigger" aria-expanded="false">
                      {{ trimmed }}
                      <span class="accordion-icon">{% render 'icon-plus' %}</span>
                    </button>
                    <div class="accordion-panel">{{ answers[forloop.index0] | strip }}</div>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </section>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{%- stylesheet -%}
.faq-nav { display: flex; flex-wrap: wrap; gap: .5rem; padding-bottom: 2rem; margin-bottom: 2rem; border-bottom: 1px solid var(--line); }
.faq-nav-chip { height: 40px; display: inline-flex; align-items: center; padding: 0 1rem; border: 1px solid var(--line); font-size: 12px; letter-spacing: .12em; text-transform: uppercase; font-weight: 500; transition: background .2s, color .2s, border-color .2s; }
.faq-nav-chip:hover { background: var(--ink); color: var(--cream); border-color: var(--ink); }
.faq-groups { display: flex; flex-direction: column; gap: 3.5rem; }
.faq-group { scroll-margin-top: 6rem; }
{%- endstylesheet -%}

{% schema %}
{
  "name": "FAQ Page",
  "settings": [],
  "blocks": [
    {
      "type": "group",
      "name": "FAQ group",
      "settings": [
        {
          "type": "text",
          "id": "anchor",
          "label": "Anchor id",
          "default": "products"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Group title",
          "default": "About Our Products"
        },
        {
          "type": "textarea",
          "id": "questions",
          "label": "Questions (one per line)",
          "default": "What makes Lumisca devices different?\nAre Lumisca devices certified?\nWhere are they made?"
        },
        {
          "type": "textarea",
          "id": "answers",
          "label": "Answers (matching order, one per line)",
          "default": "Three things. Clinical wavelengths, hands-free design and a proper 90-day money-back guarantee.\nYes — CE-certified and tested to UK and EU electrical safety standards.\nDesigned in the UK, manufactured in a Shenzhen medical-device facility, assembled in the Midlands."
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "FAQ Page"
    }
  ]
}
{% endschema %}
