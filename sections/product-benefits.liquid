<section class="section product-benefits" style="background: rgba(232,230,227,.3);">
  <div class="container">
    <div class="center" style="max-width: 36rem; margin: 0 auto 2.5rem;">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="display-md">{{ section.settings.heading }}</h2>
    </div>
    <div class="grid grid-sm-2 grid-lg-3">
      {%- for block in section.blocks -%}
        <div class="pb-card" {{ block.shopify_attributes }}>
          <div class="pb-icon">{{ block.settings.icon }}</div>
          <h3 class="pb-title">{{ block.settings.title }}</h3>
          <p class="muted">{{ block.settings.body }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- stylesheet -%}
.pb-card { background: var(--cream); padding: 1.5rem; border: 1px solid var(--line); }
@media (min-width: 768px) { .pb-card { padding: 2rem; } }
.pb-icon { font-size: 1.875rem; margin-bottom: .75rem; }
.pb-title { font-family: var(--display); font-size: 1.125rem; margin-bottom: .5rem; }
@media (min-width: 768px) { .pb-title { font-size: 1.25rem; } }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Product Benefits",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why It Works" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Engineered for real results." }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "text", "id": "icon", "label": "Emoji icon", "default": "⚡" },
        { "type": "text", "id": "title", "label": "Title", "default": "Clinical Wavelengths" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "Dual 650nm + 850nm light — the exact wavelengths used in Harley Street clinics." }
      ]
    }
  ],
  "max_blocks": 6,
  "default": {
    "blocks": [
      { "type": "benefit", "settings": { "icon": "⚡", "title": "272 Medical LEDs", "body": "Clinic-grade coverage across entire scalp." } },
      { "type": "benefit", "settings": { "icon": "🔬", "title": "Dual Wavelength", "body": "650nm surface + 850nm deep penetration." } },
      { "type": "benefit", "settings": { "icon": "🙌", "title": "Hands-Free", "body": "Wear while you work, cook or watch TV." } },
      { "type": "benefit", "settings": { "icon": "⏱", "title": "Auto-Shutoff Timer", "body": "Clinically optimal session length every time." } },
      { "type": "benefit", "settings": { "icon": "🔋", "title": "USB-C Charging", "body": "Cordless freedom between sessions." } },
      { "type": "benefit", "settings": { "icon": "🛡", "title": "60-Day Guarantee", "body": "Love it or full refund — no questions asked." } }
    ]
  },
  "presets": [ { "name": "Product Benefits" } ]
}
{% endschema %}
