{%- liquid
  assign handle = product.handle | default: ''
  assign cat = 'hair'
  if handle contains 'face' or handle contains 'glow' or handle contains 'mask'
    assign cat = 'face'
  endif
  if handle contains 'eye' or handle contains 'rest'
    assign cat = 'eye'
  endif
  if handle contains 'bundle' or handle contains 'complete'
    assign cat = 'bundle'
  endif

  assign card3_title = 'Medical-Grade Safety'
  assign card3_body = 'CE-certified and tested to medical device standards. No UV, no chemicals, no downtime.'
  case cat
    when 'hair'
      assign card3_title = 'Tailored For Real Hair Loss'
      assign card3_body = 'Works for pattern hair loss, thinning, and post-partum shedding — without drugs or surgery.'
    when 'face'
      assign card3_title = 'Built For Every Skin Goal'
      assign card3_body = 'Effective for fine lines, acne, dullness, and uneven tone — safe for sensitive skin.'
    when 'eye'
      assign card3_title = 'Gentle Heat Therapy'
      assign card3_body = 'Calms tension for sleep, migraines, and screen-fatigued eyes — no UV, no pressure.'
    when 'bundle'
      assign card3_title = 'One Ritual, Three Results'
      assign card3_body = 'Hair density, skin quality, and deeper sleep — all in one coherent daily routine.'
  endcase
-%}

<section class="pwhy">
  <div class="container">
    <div class="pwhy-head">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="display-md">{{ section.settings.heading }}</h2>
    </div>

    <div class="pwhy-grid">
      <article class="pwhy-card">
        <div class="pwhy-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12c2-3 4-3 6 0s4 3 6 0 4-3 6 0"/><path d="M2 17c2-3 4-3 6 0s4 3 6 0 4-3 6 0"/><path d="M2 7c2-3 4-3 6 0s4 3 6 0 4-3 6 0"/></svg>
        </div>
        <h3 class="pwhy-title">Clinical Wavelengths</h3>
        <p class="pwhy-body">660nm + 850nm — the only wavelengths proven in 3,000+ peer-reviewed studies to trigger cellular regeneration.</p>
      </article>

      <article class="pwhy-card">
        <div class="pwhy-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
        </div>
        <h3 class="pwhy-title">10-Minute Daily Ritual</h3>
        <p class="pwhy-body">Hands-free use. Works while you do everything else — morning coffee, evening wind-down, or after a workout.</p>
      </article>

      <article class="pwhy-card">
        <div class="pwhy-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l8 4v6c0 5-3.5 8-8 10-4.5-2-8-5-8-10V6l8-4z"/><path d="M9 12l2 2 4-4"/></svg>
        </div>
        <h3 class="pwhy-title">{{ card3_title }}</h3>
        <p class="pwhy-body">{{ card3_body }}</p>
      </article>
    </div>
  </div>
</section>

{%- stylesheet -%}
.pwhy { background: var(--cream); padding: 80px 0; }
@media (max-width: 768px) { .pwhy { padding: 56px 0; } }
.pwhy-head { text-align: center; max-width: 680px; margin: 0 auto 3rem; }
.pwhy-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
@media (min-width: 900px) { .pwhy-grid { grid-template-columns: repeat(3, 1fr); gap: 1.75rem; } }
.pwhy-card { background: #fff; border: 1px solid var(--line); border-radius: 12px; padding: 2rem; text-align: center; transition: transform .2s, box-shadow .2s; }
.pwhy-card:hover { transform: translateY(-4px); box-shadow: 0 20px 60px -22px rgba(10,10,10,.15); }
.pwhy-icon { width: 56px; height: 56px; margin: 0 auto 1.25rem; display: inline-flex; align-items: center; justify-content: center; background: rgba(200,16,46,.08); border-radius: 50%; color: var(--red); }
.pwhy-icon svg { width: 32px; height: 32px; }
.pwhy-title { font-family: var(--display); font-size: 1.25rem; line-height: 1.25; margin: 0 0 .6rem; }
.pwhy-body { color: var(--mid); font-size: 15px; line-height: 1.65; margin: 0; }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Why It Works",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "WHY IT WORKS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Engineered for real results." }
  ],
  "presets": [ { "name": "Why It Works" } ]
}
{% endschema %}
